---
import ImagePlaceholder from './ImagePlaceholder.astro';

interface Props {
  title: string;
  tags: string[];
  description: string;
  href: string;
}

const { title, tags, description, href } = Astro.props;
---

<a href={href} class="group grid grid-cols-1 md:grid-cols-2 gap-8 items-center">
  <div class="overflow-hidden rounded-[2px]">
    <ImagePlaceholder
      aspect="4/3"
      alt={title}
      class="w-full transition-transform duration-500 group-hover:scale-[1.02]"
    />
  </div>
  <div>
    <div class="flex flex-wrap gap-2 mb-4">
      {tags.map((tag) => (
        <span class="text-[0.75rem] font-medium uppercase tracking-wider text-text-muted bg-bg-secondary px-3 py-1 rounded-[2px]">
          {tag}
        </span>
      ))}
    </div>
    <h3 class="text-h3">{title}</h3>
    <p class="mt-3 text-text-secondary">{description}</p>
    <span class="inline-block mt-4 text-[0.875rem] font-medium text-gold-on-light group-hover:text-hover-gold transition-colors duration-200">
      Zobrazit detail &rarr;
    </span>
  </div>
</a>
