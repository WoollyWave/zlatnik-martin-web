---
const currentYear = new Date().getFullYear();
---

<footer class="bg-bg-primary border-t border-divider">
  <div class="max-w-[1400px] mx-auto px-8 pt-20 pb-8">

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-[1.2fr_0.8fr_0.8fr_0.8fr] gap-12 lg:gap-8">

      <!-- Brand -->
      <div>
        <div class="flex items-center gap-3">
          <span class="w-10 h-10 rounded-full border border-text-primary/15 flex items-center justify-center text-[0.75rem] font-medium tracking-wider text-text-primary">MŠ</span>
          <span>
            <span class="block text-[0.6rem] uppercase tracking-[0.2em] text-text-muted leading-none">Zlatnická dílna</span>
            <span class="block font-serif italic text-[1rem] text-text-primary leading-tight mt-0.5">Martin Ševr</span>
          </span>
        </div>
        <p class="mt-6 text-[0.875rem] text-text-muted leading-relaxed max-w-[280px]">
          Ruční výroba šperků ze zlata, stříbra a přírodních kamenů. Každý kus originál, vyrobený v pražské dílně.
        </p>
      </div>

      <!-- Navigation -->
      <nav aria-label="Patičková navigace">
        <h4 class="text-[0.6875rem] uppercase tracking-[0.15em] font-medium text-text-muted mb-6">Navigace</h4>
        <ul class="flex flex-col gap-3">
          <li><a href="/" class="text-[0.875rem] text-text-secondary hover:text-text-primary transition-colors duration-200">Domů</a></li>
          <li><a href="/zakazkova-tvorba" class="text-[0.875rem] text-text-secondary hover:text-text-primary transition-colors duration-200">Zakázková tvorba</a></li>
          <li><a href="/skladem" class="text-[0.875rem] text-text-secondary hover:text-text-primary transition-colors duration-200">Skladem</a></li>
          <li><a href="/portfolio" class="text-[0.875rem] text-text-secondary hover:text-text-primary transition-colors duration-200">Portfolio</a></li>
          <li><a href="/o-dilne" class="text-[0.875rem] text-text-secondary hover:text-text-primary transition-colors duration-200">O dílně</a></li>
        </ul>
      </nav>

      <!-- Contact -->
      <div>
        <h4 class="text-[0.6875rem] uppercase tracking-[0.15em] font-medium text-text-muted mb-6">Kontakt</h4>
        <ul class="flex flex-col gap-3 text-[0.875rem] text-text-secondary">
          <li><a href="tel:+420774598181" class="hover:text-text-primary transition-colors duration-200">+420 774 598 181</a></li>
          <li><a href="mailto:zlatnikmartin@email.cz" class="hover:text-text-primary transition-colors duration-200">zlatnikmartin@email.cz</a></li>
          <li>Pod Kesnerkou 46</li>
          <li>Praha 5, 150 00</li>
        </ul>
      </div>

      <!-- Elsewhere -->
      <div>
        <h4 class="text-[0.6875rem] uppercase tracking-[0.15em] font-medium text-text-muted mb-6">Jinam</h4>
        <ul class="flex flex-col gap-3 text-[0.875rem] text-text-secondary">
          <li><a href="https://wa.me/420774598181" target="_blank" rel="noopener noreferrer" class="hover:text-text-primary transition-colors duration-200">WhatsApp</a></li>
          <li><a href="/kontakt" class="hover:text-text-primary transition-colors duration-200">Nezávazná konzultace</a></li>
        </ul>
      </div>
    </div>

    <!-- Copyright -->
    <div class="mt-20 pt-6 border-t border-divider flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-[0.75rem] text-text-muted">&copy; {currentYear} Martin Ševr &mdash; Zlatnická dílna Praha</p>
      <span class="text-[0.75rem] text-text-muted">IČO 87639114</span>
    </div>

  </div>
</footer>
