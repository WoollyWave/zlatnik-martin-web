---
const currentYear = new Date().getFullYear();
---

<section class="relative overflow-hidden bg-bg-primary">
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(198,168,90,0.05),transparent_24%),radial-gradient(circle_at_bottom_right,rgba(30,27,24,0.03),transparent_22%)]"></div>
  </div>

  <div class="relative max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-14 pt-16 sm:pt-20 lg:pt-24 pb-8 sm:pb-10 lg:pb-12">
    <!-- CTA Panel -->
    <div data-anim="up" class="relative border border-border bg-[rgba(250,251,248,0.6)] backdrop-blur-sm px-6 sm:px-8 lg:px-12 py-12 sm:py-14 lg:py-20 overflow-hidden">

      <!-- Subtle gold radial glow behind photo -->
      <div class="hidden lg:block absolute right-[8%] top-1/2 -translate-y-1/2 w-[450px] h-[450px] bg-[radial-gradient(circle,rgba(198,168,90,0.06)_0%,transparent_65%)] pointer-events-none"></div>

      <div class="grid grid-cols-1 lg:grid-cols-[1fr_0.55fr] gap-8 lg:gap-12 items-center relative">
        <div>
          <h2 class="font-serif text-text-primary tracking-[-0.02em] leading-[1.1] text-[1.75rem] sm:text-[2.2rem] lg:text-[2.8rem]">
            <span class="block">Pojďme vytvořit</span>
            <span class="block">šperk, který krásně</span>
            <span class="block italic text-gold-deep">zestárne.</span>
          </h2>

          <div class="mt-8 flex flex-col sm:flex-row items-stretch sm:items-center gap-4 relative z-20">
            <a href="tel:+420774598181"
              class="inline-flex items-center justify-center gap-3 h-12 px-8 rounded-full bg-text-primary border border-text-primary hover:bg-gold-deep hover:border-gold-deep transition-all duration-300 font-sans text-[11px] uppercase tracking-[0.2em] font-medium shadow-md"
              style="color: #FAFBF8;">
              Zavolat
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" /></svg>
            </a>
            <a href="https://wa.me/420774598181" target="_blank" rel="noopener noreferrer"
              aria-label="Napsat na WhatsApp"
              class="inline-flex items-center justify-center gap-2 h-12 px-6 rounded-full border border-border bg-[rgba(250,251,248,0.8)] text-text-primary hover:bg-white transition-all duration-300 font-sans text-[11px] uppercase tracking-[0.2em] font-medium shadow-sm">
              Napsat na WhatsApp
            </a>
          </div>
        </div>

        <!-- Photo — floating ring (mobile: first, desktop: second) -->
        <div class="flex items-center justify-center relative order-first lg:order-none">
          <img
            src="/images/footer--cta--prsten-detail.webp"
            srcset="/images/footer--cta--prsten-detail.webp 1x, /images/footer--cta--prsten-detail@2x.webp 2x"
            width="600" height="500"
            alt="Detail ručně vyrobeného prstenu"
            loading="lazy"
            decoding="async"
            class="cta-ring w-full max-w-[180px] sm:max-w-[240px] lg:max-w-[300px] h-auto object-cover relative z-10"
          />
        </div>
      </div>

    </div>

    <!-- Footer -->
    <div class="pt-8 sm:pt-10 lg:pt-12">
      <div class="grid grid-cols-1 md:grid-cols-[1.4fr_0.8fr_0.8fr] gap-8 lg:gap-10 border-t border-border pt-8">
        <!-- Brand -->
        <div>
          <a href="/" class="inline-flex items-center gap-3 mb-5 group">
            <div class="h-10 w-10 rounded-full border border-border bg-white/60 flex items-center justify-center text-[12px] text-gold-deep font-medium tracking-[0.12em] uppercase font-sans group-hover:bg-gold-deep group-hover:text-white transition-colors duration-300">
              MŠ
            </div>
            <div class="flex flex-col leading-[1.1] pt-[1px]">
              <span class="text-[0.65rem] uppercase tracking-[0.22em] text-text-muted font-sans">Zlatnická dílna</span>
              <span class="text-[1.1rem] tracking-[-0.02em] text-text-primary font-serif italic">Martin Ševr</span>
            </div>
          </a>
          <p class="max-w-[18rem] text-[13px] leading-[1.8] text-text-secondary font-sans">
            Ruční výroba šperků ze zlata, stříbra a přírodních kamenů. Každý kus originál, vyrobený v pražské dílně.
          </p>
          <!-- Social -->
          <div class="flex items-center gap-4 mt-5">
            <a href="https://www.instagram.com/zlatnicka_dilna_martin_sevr/" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="text-text-muted hover:text-gold-deep transition-colors duration-300">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
            </a>
            <a href="https://www.facebook.com/MartinSevr" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="text-text-muted hover:text-gold-deep transition-colors duration-300">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/></svg>
            </a>
          </div>
        </div>

        <!-- Navigation -->
        <div>
          <p class="text-[10px] uppercase tracking-[0.18em] text-text-muted font-sans mb-4 font-medium">Navigace</p>
          <div class="flex flex-col gap-3">
            <a href="/zakazkova-tvorba" class="text-[13px] text-text-primary font-sans hover:text-gold-deep transition-colors">Zakázková tvorba</a>
            <a href="/skladem" class="text-[13px] text-text-primary font-sans hover:text-gold-deep transition-colors">Skladem</a>
            <a href="/portfolio" class="text-[13px] text-text-primary font-sans hover:text-gold-deep transition-colors">Portfolio</a>
            <a href="/o-dilne" class="text-[13px] text-text-primary font-sans hover:text-gold-deep transition-colors">O dílně</a>
            <a href="/kontakt" class="text-[13px] text-text-primary font-sans hover:text-gold-deep transition-colors">Kontakt</a>
          </div>
        </div>

        <!-- Contact -->
        <div>
          <p class="text-[10px] uppercase tracking-[0.18em] text-text-muted font-sans mb-4 font-medium">Kontakt</p>
          <div class="flex flex-col gap-3 text-[13px] text-text-primary font-sans">
            <a href="tel:+420774598181" class="hover:text-gold-deep transition-colors">+420 774 598 181</a>
            <a href="mailto:zlatnikmartin@email.cz" class="hover:text-gold-deep transition-colors">zlatnikmartin@email.cz</a>
            <a href="https://wa.me/420774598181" target="_blank" rel="noopener noreferrer" class="hover:text-gold-deep transition-colors">WhatsApp</a>
            <span>Pod Kesnerkou 46, Praha 5</span>
          </div>
        </div>
      </div>

      <!-- Copyright -->
      <div class="mt-8 pt-5 border-t border-border flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
        <p class="text-[11px] uppercase tracking-[0.18em] text-text-muted font-sans">
          &copy; {currentYear} Martin Ševr — Zlatnická dílna Praha | IČO 87639114
        </p>
      </div>
    </div>
  </div>
</section>
