---
const navLinks = [
  { label: 'Domů', href: '/' },
  { label: 'Zakazkov\u00E1 tvorba', href: '/zakazkova-tvorba' },
  { label: 'Skladem', href: '/skladem' },
  { label: 'Portfolio', href: '/portfolio' },
  { label: 'O d\u00EDln\u011B', href: '/o-dilne' },
  { label: 'Kontakt', href: '/kontakt' },
];

const currentYear = new Date().getFullYear();
---

<footer class="bg-bg-secondary border-t border-border">
  <div class="max-w-[1280px] mx-auto px-6 py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 md:gap-8">
      <!-- Brand -->
      <div>
        <a href="/" class="font-serif italic text-[1.35rem] font-light text-text-primary tracking-tight">
          Martin Ševr
        </a>
        <p class="mt-3 text-[0.875rem] text-text-secondary leading-relaxed">
          Zlatnická dílna v centru Prahy
        </p>
      </div>

      <!-- Navigation -->
      <nav aria-label="Patickov\u00E1 navigace">
        <h4 class="font-sans text-[0.75rem] font-medium uppercase tracking-wider text-text-muted mb-4">
          Navigace
        </h4>
        <ul class="flex flex-col gap-3">
          {navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-[0.875rem] text-text-secondary hover:text-text-primary transition-colors duration-200"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- Contact -->
      <div>
        <h4 class="font-sans text-[0.75rem] font-medium uppercase tracking-wider text-text-muted mb-4">
          Kontakt
        </h4>
        <ul class="flex flex-col gap-3 text-[0.875rem] text-text-secondary">
          <li>
            <a href="tel:+420774598181" class="hover:text-text-primary transition-colors duration-200">
              +420 774 598 181
            </a>
          </li>
          <li>
            <a href="mailto:zlatnikmartin@email.cz" class="hover:text-text-primary transition-colors duration-200">
              zlatnikmartin@email.cz
            </a>
          </li>
          <li>
            Pod Kesnerkou 46, Praha 5
          </li>
        </ul>
      </div>
    </div>

    <!-- Copyright -->
    <div class="mt-12 pt-8 border-t border-divider flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-[0.75rem] text-text-muted">
        &copy; {currentYear} Martin Ševr &middot; Zlatnická dílna Praha
      </p>
      <div class="flex gap-4">
        <a href="/ochrana-udaju" class="text-[0.75rem] text-text-muted hover:text-text-secondary transition-colors duration-200">
          Ochrana osobních údajů
        </a>
        <a href="/obchodni-podminky" class="text-[0.75rem] text-text-muted hover:text-text-secondary transition-colors duration-200">
          Obchodní podmínky
        </a>
      </div>
    </div>

    <!-- Design credit -->
    <div class="mt-4 text-center">
      <p class="text-[0.6875rem] text-text-muted/60">
        Design &amp; web <a href="https://vilim.one" target="_blank" rel="noopener noreferrer" class="hover:text-text-muted transition-colors duration-200">Vilim.One</a>
      </p>
    </div>
  </div>
</footer>
