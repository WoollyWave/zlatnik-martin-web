---
const currentPath = Astro.url.pathname;

const navLinks = [
  { label: 'Domů', href: '/' },
  { label: 'Zakázková tvorba', href: '/zakazkova-tvorba' },
  { label: 'Skladem', href: '/skladem' },
  { label: 'Portfolio', href: '/portfolio' },
  { label: 'O dílně', href: '/o-dilne' },
];
---

<header
  id="navbar"
  class="fixed top-0 left-0 right-0 z-50 bg-bg-primary/95 backdrop-blur-sm transition-all duration-300"
>
  <nav class="max-w-[1400px] mx-auto px-5 md:px-8 flex items-center justify-between h-20" aria-label="Hlavní navigace">
    <!-- Logo: monogram + text -->
    <a href="/" class="flex items-center gap-3" aria-label="Martin Ševr — Domů">
      <span class="w-10 h-10 rounded-full border border-text-primary/20 flex items-center justify-center text-[0.75rem] font-medium tracking-wider text-text-primary">MŠ</span>
      <span class="hidden sm:block">
        <span class="block text-[0.6rem] uppercase tracking-[0.2em] text-text-muted leading-none">Zlatnická dílna</span>
        <span class="block font-serif italic text-[1rem] text-text-primary leading-tight mt-0.5">Martin Ševr</span>
      </span>
    </a>

    <!-- Center links -->
    <ul class="hidden lg:flex items-center gap-10">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class={`text-[0.8125rem] tracking-[0.04em] transition-colors duration-200 ${
              currentPath === link.href || currentPath === link.href + '/'
                ? 'text-text-primary'
                : 'text-text-secondary hover:text-text-primary'
            }`}
            aria-current={currentPath === link.href || currentPath === link.href + '/' ? 'page' : undefined}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Right: status indicator + CTA -->
    <div class="hidden lg:flex items-center gap-8">
      <span class="flex items-center gap-2 text-[0.75rem] tracking-[0.06em] text-text-secondary">
        <span class="w-1.5 h-1.5 rounded-full bg-success pulse-dot"></span>
        Přijímám zakázky
      </span>
      <a
        href="/kontakt"
        class="bg-text-primary text-[0.8125rem] font-medium px-6 py-3 hover:bg-gold-deep transition-colors duration-300"
        style="color: #FAFBF8;"
      >
        Nezávazná konzultace
      </a>
    </div>

    <!-- Mobile: 2 lines hamburger -->
    <button
      id="mobile-menu-toggle"
      class="lg:hidden flex flex-col justify-center items-center w-10 h-10 gap-2"
      aria-label="Otevřít menu"
      aria-expanded="false"
    >
      <span class="menu-line w-6 h-[1.5px] bg-text-primary transition-all duration-300 origin-center"></span>
      <span class="menu-line w-6 h-[1.5px] bg-text-primary transition-all duration-300 origin-center"></span>
    </button>
  </nav>

  <!-- Mobile menu: fullscreen, serif links -->
  <div
    id="mobile-menu"
    class="lg:hidden hidden bg-bg-primary border-t border-divider"
  >
    <div class="px-5 md:px-8 py-10 flex flex-col gap-6">
      <a href="/" class="font-serif text-[1.5rem] font-light text-text-primary">Domů</a>
      <a href="/zakazkova-tvorba" class="font-serif text-[1.5rem] font-light text-text-primary">Zakázková tvorba</a>
      <a href="/skladem" class="font-serif text-[1.5rem] font-light text-text-primary">Skladem</a>
      <a href="/portfolio" class="font-serif text-[1.5rem] font-light text-text-primary">Portfolio</a>
      <a href="/o-dilne" class="font-serif text-[1.5rem] font-light text-text-primary">O dílně</a>
      <a href="/kontakt" class="font-serif text-[1.5rem] font-light text-text-primary">Kontakt</a>
      <div class="pt-6 border-t border-divider flex flex-col gap-3">
        <a href="tel:+420774598181" class="bg-text-primary text-center text-[0.9375rem] font-medium px-7 py-4 hover:bg-gold-deep transition-colors duration-300" style="color: #FAFBF8;">Zavolat</a>
        <a href="https://wa.me/420774598181" target="_blank" rel="noopener noreferrer" class="border border-text-primary/15 text-text-primary text-center text-[0.9375rem] font-medium px-7 py-4 hover:bg-hover-bg transition-colors duration-300">WhatsApp</a>
      </div>
    </div>
  </div>
</header>

<!-- Spacer for fixed nav -->
<div class="h-20"></div>

<script>
  // Mobile menu toggle
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const lines = toggle?.querySelectorAll('.menu-line');

  toggle?.addEventListener('click', () => {
    const isOpen = menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    toggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');

    if (lines) {
      if (isOpen) {
        lines[0].classList.add('rotate-45', 'translate-y-[5px]');
        lines[1].classList.add('-rotate-45', '-translate-y-[5px]');
      } else {
        lines[0].classList.remove('rotate-45', 'translate-y-[5px]');
        lines[1].classList.remove('-rotate-45', '-translate-y-[5px]');
      }
    }
  });

  // Shadow on scroll
  const navbar = document.getElementById('navbar');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 10) {
      navbar?.classList.add('shadow-[0_2px_8px_rgba(0,0,0,0.06)]', 'border-b', 'border-divider');
    } else {
      navbar?.classList.remove('shadow-[0_2px_8px_rgba(0,0,0,0.06)]', 'border-b', 'border-divider');
    }
  });
</script>
