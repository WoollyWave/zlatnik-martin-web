---
const currentPath = Astro.url.pathname;

const navLinks = [
  { label: 'Zakazkov\u00E1 tvorba', href: '/zakazkova-tvorba' },
  { label: 'Skladem', href: '/skladem' },
  { label: 'Portfolio', href: '/portfolio' },
  { label: 'O d\u00EDln\u011B', href: '/o-dilne' },
  { label: 'Kontakt', href: '/kontakt' },
];
---

<header
  id="navbar"
  class="fixed top-0 left-0 right-0 z-50 bg-bg-primary/95 backdrop-blur-sm transition-shadow duration-300"
>
  <nav class="max-w-[1280px] mx-auto px-6 flex items-center justify-between h-[72px]" aria-label="Hlavní navigace">
    <!-- Logo -->
    <a href="/" class="font-serif italic text-[1.35rem] font-light text-text-primary tracking-tight" aria-label="Martin Ševr — Domů">
      Martin Ševr
    </a>

    <!-- Desktop links -->
    <ul class="hidden lg:flex items-center gap-8">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class={`relative font-sans text-[0.875rem] transition-colors duration-200 after:absolute after:bottom-[-2px] after:left-0 after:h-[1px] after:bg-gold-primary after:transition-all after:duration-300 ${
              currentPath === link.href || currentPath === link.href + '/'
                ? 'text-text-primary after:w-full'
                : 'text-text-secondary hover:text-text-primary after:w-0 hover:after:w-full'
            }`}
            aria-current={currentPath === link.href || currentPath === link.href + '/' ? 'page' : undefined}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- CTA buttons -->
    <div class="hidden lg:flex items-center gap-3">
      <a
        href="https://wa.me/420774598181"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center font-sans font-medium uppercase tracking-wider text-[0.75rem] px-5 py-2.5 rounded-[2px] border border-border text-text-primary hover:bg-hover-bg transition-all duration-200 hover:translate-y-[-1px] active:translate-y-0"
        aria-label="Napsat na WhatsApp"
      >
        WhatsApp
      </a>
      <a
        href="tel:+420774598181"
        class="inline-flex items-center justify-center font-sans font-medium uppercase tracking-wider text-[0.75rem] px-5 py-2.5 rounded-[2px] bg-text-primary text-bg-primary hover:bg-gold-primary transition-all duration-200 hover:translate-y-[-1px] active:translate-y-0"
        aria-label="Zavolat"
      >
        Volat
      </a>
    </div>

    <!-- Mobile menu button -->
    <button
      id="mobile-menu-toggle"
      class="lg:hidden flex flex-col justify-center items-center w-10 h-10 gap-1.5"
      aria-label="Otevřít menu"
      aria-expanded="false"
    >
      <span class="menu-line w-6 h-[1.5px] bg-text-primary transition-all duration-300 origin-center"></span>
      <span class="menu-line w-6 h-[1.5px] bg-text-primary transition-all duration-300 origin-center"></span>
      <span class="menu-line w-6 h-[1.5px] bg-text-primary transition-all duration-300 origin-center"></span>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="lg:hidden hidden bg-bg-primary border-t border-divider"
  >
    <div class="px-6 py-8 flex flex-col gap-6">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class={`font-sans text-[1.125rem] transition-colors duration-200 ${
            currentPath === link.href || currentPath === link.href + '/'
              ? 'text-gold-on-light font-medium'
              : 'text-text-primary hover:text-gold-on-light'
          }`}
          aria-current={currentPath === link.href || currentPath === link.href + '/' ? 'page' : undefined}
        >
          {link.label}
        </a>
      ))}
      <div class="flex flex-col gap-3 pt-4 border-t border-divider">
        <a
          href="https://wa.me/420774598181"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center font-sans font-medium uppercase tracking-wider text-[0.8125rem] px-7 py-3.5 rounded-[2px] border border-border text-text-primary hover:bg-hover-bg transition-colors duration-200"
        >
          WhatsApp
        </a>
        <a
          href="tel:+420774598181"
          class="inline-flex items-center justify-center font-sans font-medium uppercase tracking-wider text-[0.8125rem] px-7 py-3.5 rounded-[2px] bg-text-primary text-bg-primary hover:bg-gold-primary transition-colors duration-200"
        >
          Volat
        </a>
      </div>
    </div>
  </div>
</header>

<!-- Spacer for fixed nav -->
<div class="h-[72px]"></div>

<script>
  // Mobile menu toggle
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const lines = toggle?.querySelectorAll('.menu-line');

  toggle?.addEventListener('click', () => {
    const isOpen = menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    toggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');

    if (lines) {
      if (isOpen) {
        lines[0].classList.add('rotate-45', 'translate-y-[4.5px]');
        lines[1].classList.add('opacity-0');
        lines[2].classList.add('-rotate-45', '-translate-y-[4.5px]');
      } else {
        lines[0].classList.remove('rotate-45', 'translate-y-[4.5px]');
        lines[1].classList.remove('opacity-0');
        lines[2].classList.remove('-rotate-45', '-translate-y-[4.5px]');
      }
    }
  });

  // Shadow on scroll
  const navbar = document.getElementById('navbar');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 10) {
      navbar?.classList.add('shadow-[0_2px_8px_rgba(0,0,0,0.06)]', 'border-b', 'border-divider');
    } else {
      navbar?.classList.remove('shadow-[0_2px_8px_rgba(0,0,0,0.06)]', 'border-b', 'border-divider');
    }
  });
</script>
