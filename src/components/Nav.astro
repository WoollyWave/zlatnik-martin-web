---
const currentPath = Astro.url.pathname;
const navLinks = [
  { label: 'Zakázková tvorba', href: '/zakazkova-tvorba' },
  { label: 'Skladem', href: '/skladem' },
  { label: 'Portfolio', href: '/portfolio' },
  { label: 'O dílně', href: '/o-dilne' },
  { label: 'Kontakt', href: '/kontakt' },
];
---

<header class="fixed top-4 inset-x-0 z-50 px-4 sm:px-5">
  <div class="max-w-[1400px] mx-auto">
    <nav id="main-nav" class="relative flex items-center justify-between h-[72px] px-2 sm:px-3 lg:px-4 rounded-full border border-border/75 bg-[rgba(241,238,229,0.88)] backdrop-blur-xl shadow-[0_10px_30px_rgba(30,27,24,0.06)]" aria-label="Hlavní navigace">

      <!-- Subtle top highlight -->
      <div class="pointer-events-none absolute inset-x-8 top-0 h-px bg-gradient-to-r from-transparent via-white/80 to-transparent"></div>

      <!-- Brand -->
      <a href="/" class="flex items-center gap-2.5 shrink-0 relative z-20" aria-label="Martin Ševr — Domů">
        <div class="h-11 w-11 rounded-full border border-border bg-white/70 flex items-center justify-center text-[12px] text-gold-deep font-medium tracking-[0.12em] uppercase font-sans shadow-[inset_0_1px_0_rgba(255,255,255,0.7)]">
          MŠ
        </div>
        <div class="hidden sm:flex flex-col leading-[1.1] pt-[1px]">
          <span class="text-[0.65rem] uppercase tracking-[0.22em] text-text-muted font-sans">Zlatnická dílna</span>
          <span class="text-[1.1rem] tracking-[-0.02em] text-text-primary font-serif italic">Martin Ševr</span>
        </div>
      </a>

      <!-- Center links — desktop -->
      <ul class="hidden lg:flex items-center gap-8 absolute left-1/2 -translate-x-1/2">
        {navLinks.map((link) => (
          <li>
            <a href={link.href}
              class={`text-[11px] uppercase tracking-[0.2em] font-sans font-medium transition-colors whitespace-nowrap ${
                currentPath === link.href || currentPath === link.href + '/'
                  ? 'text-gold-deep' : 'text-text-secondary hover:text-gold-deep'
              }`}>
              {link.label}
            </a>
          </li>
        ))}
      </ul>

      <!-- Right: status + CTA -->
      <div class="hidden lg:flex items-center gap-6">
        <span class="flex items-center gap-2 text-[11px] tracking-[0.1em] text-text-secondary font-sans font-medium">
          <span class="w-1.5 h-1.5 rounded-full bg-success pulse-dot"></span>
          Přijímám zakázky
        </span>
        <a href="/kontakt"
          class="inline-flex items-center gap-2 h-11 px-6 bg-text-primary rounded-full font-sans text-[11px] uppercase tracking-[0.2em] font-medium shadow-md hover:bg-gold-deep transition-colors duration-300"
          style="color: #FAFBF8;">
          Konzultace
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25" /></svg>
        </a>
      </div>

      <!-- Mobile toggle -->
      <button id="mobile-menu-toggle" class="lg:hidden flex flex-col justify-center items-center w-10 h-10 gap-2" aria-label="Otevřít menu" aria-expanded="false">
        <span class="menu-line w-5 h-[1.5px] bg-text-primary transition-all duration-300 origin-center"></span>
        <span class="menu-line w-5 h-[1.5px] bg-text-primary transition-all duration-300 origin-center"></span>
      </button>
    </nav>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="lg:hidden hidden mt-2 mx-auto max-w-[1400px]">
    <div class="rounded-3xl border border-border/80 bg-[rgba(241,238,229,0.96)] backdrop-blur-xl shadow-[0_20px_50px_rgba(30,27,24,0.10)] p-6">
      <div class="flex flex-col gap-4">
        <a href="/" class="text-[13px] text-text-primary font-sans hover:text-gold-deep transition-colors py-2">Domů</a>
        {navLinks.map((link) => (
          <a href={link.href} class="text-[13px] text-text-primary font-sans hover:text-gold-deep transition-colors py-2">
            {link.label}
          </a>
        ))}
      </div>
      <div class="mt-4 pt-4 border-t border-divider flex flex-col gap-3">
        <a href="tel:+420774598181" class="inline-flex items-center justify-center h-12 bg-text-primary rounded-full font-sans text-[11px] uppercase tracking-[0.2em] font-medium shadow-md hover:bg-gold-deep transition-colors duration-300" style="color: #FAFBF8;">Zavolat</a>
        <a href="https://wa.me/420774598181" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center h-12 border border-border bg-white/80 text-text-primary rounded-full font-sans text-[11px] uppercase tracking-[0.2em] font-medium hover:bg-white transition-colors duration-300">WhatsApp</a>
      </div>
    </div>
  </div>
</header>

<!-- Spacer -->
<div class="h-24"></div>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const lines = toggle?.querySelectorAll('.menu-line');
  toggle?.addEventListener('click', () => {
    const isOpen = menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    toggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
    if (lines) {
      if (isOpen) {
        lines[0].classList.add('rotate-45', 'translate-y-[5px]');
        lines[1].classList.add('-rotate-45', '-translate-y-[5px]');
      } else {
        lines[0].classList.remove('rotate-45', 'translate-y-[5px]');
        lines[1].classList.remove('-rotate-45', '-translate-y-[5px]');
      }
    }
  });
</script>
