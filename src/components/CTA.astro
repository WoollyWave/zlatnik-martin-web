---
import Button from './Button.astro';

interface Props {
  heading?: string;
  subheading?: string;
}

const {
  heading = 'Máte zájem\no zakázkový šperk?',
  subheading = 'Zavolejte mi nebo napište. Ozvu se do 24 hodin.',
} = Astro.props;
---

<section class="bg-bg-primary section-divider py-24 md:py-40">
  <div class="max-w-[1280px] mx-auto px-6">
    <div class="text-center max-w-2xl mx-auto" data-animate="up">
      <h2 class="text-h2 whitespace-pre-line">{heading}</h2>
      <p class="mt-4 text-text-secondary text-[1.0625rem]">{subheading}</p>
      <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
        <Button href="tel:+420774598181" variant="primary">Zavolat</Button>
        <Button href="https://wa.me/420774598181" variant="secondary">Napsat na WhatsApp</Button>
      </div>
    </div>
  </div>
</section>
