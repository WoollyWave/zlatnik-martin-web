---
import ImagePlaceholder from './ImagePlaceholder.astro';

interface Props {
  title: string;
  material: string;
  price: string;
  href: string;
  category?: string;
  image?: string;
  image2x?: string;
  alt?: string;
}

const { title, material, price, href, category, image, image2x, alt } = Astro.props;
---

<a href={href} class="group block bg-white rounded-[2px] shadow-[0_2px_8px_rgba(0,0,0,0.06)] overflow-hidden transition-all duration-300 hover:shadow-[0_8px_24px_rgba(0,0,0,0.08)] hover:translate-y-[-2px]">
  <div class="overflow-hidden">
    {image ? (
      <img
        src={image}
        srcset={`${image} 1x, ${image2x} 2x`}
        width="800" height="800"
        alt={alt || title}
        loading="lazy"
        decoding="async"
        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.03]"
      />
    ) : (
      <ImagePlaceholder
        aspect="1/1"
        alt={title}
        class="w-full transition-transform duration-500 group-hover:scale-[1.03]"
      />
    )}
  </div>
  <div class="p-5">
    <h3 class="font-serif text-[1.125rem] font-normal leading-snug">{title}</h3>
    <p class="text-[0.8125rem] text-text-muted mt-1">{material}</p>
    <p class="text-[1rem] font-medium text-text-primary mt-3">{price}</p>
  </div>
</a>
