---
interface Props {
  title: string;
  material: string;
  price: string;
  href: string;
  category?: string;
  image?: string;
  image2x?: string;
  alt?: string;
  description?: string;
}

const { title, material, price, href, category, image, image2x, alt, description } = Astro.props;
---

<a href={href} class="group block border border-border hover:border-text-muted/30 transition-all duration-300" data-category={category}>

  <!-- Photo -->
  <div class="relative aspect-[4/3] overflow-hidden">
    {image ? (
      <img
        src={image}
        srcset={image2x ? `${image} 1x, ${image2x} 2x` : undefined}
        width="800" height="600"
        alt={alt || title}
        loading="lazy"
        decoding="async"
        class="absolute inset-0 w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-700"
      />
    ) : (
      <div class="absolute inset-0 bg-bg-tertiary flex items-center justify-center">
        <svg class="w-12 h-12 text-text-muted/30" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0 0 22.5 18.75V5.25A2.25 2.25 0 0 0 20.25 3H3.75A2.25 2.25 0 0 0 1.5 5.25v13.5A2.25 2.25 0 0 0 3.75 21Z" />
        </svg>
      </div>
    )}
  </div>

  <!-- Info -->
  <div class="px-5 sm:px-6 py-5 sm:py-6">
    <div class="flex items-start justify-between gap-4">
      <div>
        <h3 class="font-serif text-[1.125rem] sm:text-[1.25rem] font-normal leading-snug group-hover:text-gold-deep transition-colors duration-300">{title}</h3>
        <p class="text-[0.8125rem] text-text-muted mt-1.5 font-sans">{material}</p>
        {description && (
          <p class="text-[0.875rem] text-text-secondary mt-3 leading-relaxed font-sans line-clamp-2">{description}</p>
        )}
      </div>
      <span class="flex-shrink-0 font-sans text-[0.9375rem] font-medium text-text-primary whitespace-nowrap mt-0.5">{price}</span>
    </div>
    <div class="mt-4 pt-4 border-t border-border flex items-center justify-between">
      <span class="text-[11px] text-text-secondary uppercase tracking-[0.15em] font-sans font-medium group-hover:text-gold-deep transition-colors duration-300">Zobrazit detail</span>
      <div class="h-8 w-8 rounded-full border border-border flex items-center justify-center group-hover:bg-text-primary group-hover:border-text-primary transition-colors duration-300">
        <svg class="w-3 h-3 text-text-primary group-hover:text-white transition-colors duration-300" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25" /></svg>
      </div>
    </div>
  </div>

</a>
