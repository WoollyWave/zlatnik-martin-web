---
interface Props {
  title: string;
  material: string;
  price: string;
  href: string;
  category?: string;
  image?: string;
  image2x?: string;
  alt?: string;
}

const { title, material, price, href, category, image, image2x, alt } = Astro.props;
---

<a href={href} class="group block" data-category={category}>

  <!-- Photo -->
  <div class="relative aspect-[4/5] overflow-hidden">
    {image ? (
      <img
        src={image}
        srcset={image2x ? `${image} 1x, ${image2x} 2x` : undefined}
        width="800" height="1000"
        alt={alt || title}
        loading="lazy"
        decoding="async"
        class="absolute inset-0 w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-700"
      />
    ) : (
      <div class="absolute inset-0 bg-bg-tertiary flex items-center justify-center">
        <svg class="w-12 h-12 text-text-muted/30" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0 0 22.5 18.75V5.25A2.25 2.25 0 0 0 20.25 3H3.75A2.25 2.25 0 0 0 1.5 5.25v13.5A2.25 2.25 0 0 0 3.75 21Z" />
        </svg>
      </div>
    )}
    <!-- Price plaque -->
    <div class="absolute bottom-4 right-4 bg-bg-primary/90 backdrop-blur-md px-4 py-2">
      <span class="text-[0.8125rem] font-medium text-text-primary font-sans">{price}</span>
    </div>
  </div>

  <!-- Info — minimal -->
  <div class="mt-4">
    <h3 class="font-serif text-[1.125rem] font-normal leading-snug group-hover:text-gold-deep transition-colors duration-300">{title}</h3>
    <p class="text-[0.8125rem] text-text-muted mt-1 font-sans">{material}</p>
  </div>

</a>
