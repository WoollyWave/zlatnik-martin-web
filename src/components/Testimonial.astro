---
interface Props {
  quote: string;
  author: string;
  role?: string;
  stars?: number;
}

const { quote, author, role, stars = 5 } = Astro.props;
---

<section class="bg-bg-primary py-20 md:py-28">
  <div class="max-w-3xl mx-auto px-6 text-center" data-animate="up">
    <!-- Stars -->
    <div class="flex items-center justify-center gap-1 mb-8">
      {Array.from({ length: stars }).map(() => (
        <svg class="w-5 h-5 text-gold-primary" fill="currentColor" viewBox="0 0 20 20">
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
        </svg>
      ))}
    </div>

    <!-- Quote -->
    <blockquote class="border-l-2 border-gold-primary pl-6 md:pl-8 text-left md:border-l-0 md:pl-0 md:text-center">
      <p class="font-serif italic text-[1.375rem] md:text-[1.625rem] leading-relaxed text-text-primary font-light">
        &ldquo;{quote}&rdquo;
      </p>
    </blockquote>

    <!-- Author -->
    <div class="mt-8">
      <p class="font-sans font-medium text-text-primary">{author}</p>
      {role && (
        <p class="text-[0.875rem] text-text-muted mt-1">{role}</p>
      )}
    </div>
  </div>
</section>
