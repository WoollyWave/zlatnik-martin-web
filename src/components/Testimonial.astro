---
interface Props {
  quote: string;
  author: string;
  role?: string;
}

const { quote, author, role } = Astro.props;
---

<section class="bg-bg-primary border-b border-border py-20 md:py-32">
  <div class="max-w-3xl mx-auto px-6 sm:px-8 lg:px-14 text-center" data-anim="up">
    <blockquote>
      <p class="font-serif italic text-[1.375rem] md:text-[1.75rem] leading-relaxed text-text-primary font-normal">
        &bdquo;{quote}&ldquo;
      </p>
    </blockquote>
    <div class="mt-8">
      <p class="font-sans font-medium text-text-primary">{author}</p>
      {role && (
        <p class="text-[0.875rem] text-text-muted mt-1">{role}</p>
      )}
    </div>
  </div>
</section>
