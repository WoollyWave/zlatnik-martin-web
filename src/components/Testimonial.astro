---
interface Props {
  quote: string;
  author: string;
  role?: string;
}

const { quote, author, role } = Astro.props;
---

<section class="bg-bg-primary section-divider py-20 md:py-32">
  <div class="max-w-3xl mx-auto px-6 text-center" data-animate="up">
    <blockquote>
      <p class="font-serif italic text-[1.375rem] md:text-[1.625rem] leading-relaxed text-text-primary font-light">
        &ldquo;{quote}&rdquo;
      </p>
    </blockquote>

    <div class="mt-8">
      <p class="font-sans font-medium text-text-primary">{author}</p>
      {role && (
        <p class="text-[0.875rem] text-text-muted mt-1">{role}</p>
      )}
    </div>
  </div>
</section>
