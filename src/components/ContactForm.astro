---
import Button from './Button.astro';
---

<form class="space-y-6" action="#" method="POST">
  <div>
    <label for="name" class="block text-[0.875rem] font-medium text-text-primary mb-2">Jméno</label>
    <input
      type="text"
      id="name"
      name="name"
      required
      class="w-full px-4 py-3 bg-white border border-border rounded-[2px] text-text-primary text-[0.9375rem] focus:outline-none focus:ring-2 focus:ring-gold-primary/35 focus:border-gold-primary transition-colors duration-200"
      placeholder="Vaše jméno"
    />
  </div>

  <div>
    <label for="email" class="block text-[0.875rem] font-medium text-text-primary mb-2">E-mail</label>
    <input
      type="email"
      id="email"
      name="email"
      required
      class="w-full px-4 py-3 bg-white border border-border rounded-[2px] text-text-primary text-[0.9375rem] focus:outline-none focus:ring-2 focus:ring-gold-primary/35 focus:border-gold-primary transition-colors duration-200"
      placeholder="vas@email.cz"
    />
  </div>

  <div>
    <label for="phone" class="block text-[0.875rem] font-medium text-text-primary mb-2">Telefon</label>
    <input
      type="tel"
      id="phone"
      name="phone"
      class="w-full px-4 py-3 bg-white border border-border rounded-[2px] text-text-primary text-[0.9375rem] focus:outline-none focus:ring-2 focus:ring-gold-primary/35 focus:border-gold-primary transition-colors duration-200"
      placeholder="+420 ..."
    />
  </div>

  <div>
    <label for="interest" class="block text-[0.875rem] font-medium text-text-primary mb-2">Zájem o</label>
    <select
      id="interest"
      name="interest"
      class="w-full px-4 py-3 bg-white border border-border rounded-[2px] text-text-primary text-[0.9375rem] focus:outline-none focus:ring-2 focus:ring-gold-primary/35 focus:border-gold-primary transition-colors duration-200"
    >
      <option value="">Vyberte...</option>
      <option value="zakazka">Zakázkový šperk</option>
      <option value="skladem">Šperk skladem</option>
      <option value="oprava">Oprava šperků</option>
      <option value="konzultace">Konzultace</option>
      <option value="jine">Jiné</option>
    </select>
  </div>

  <div>
    <label for="message" class="block text-[0.875rem] font-medium text-text-primary mb-2">Zpráva</label>
    <textarea
      id="message"
      name="message"
      rows="5"
      class="w-full px-4 py-3 bg-white border border-border rounded-[2px] text-text-primary text-[0.9375rem] focus:outline-none focus:ring-2 focus:ring-gold-primary/35 focus:border-gold-primary transition-colors duration-200 resize-vertical"
      placeholder="Popište svou představu..."
    ></textarea>
  </div>

  <div class="flex items-start gap-3">
    <input
      type="checkbox"
      id="gdpr"
      name="gdpr"
      required
      class="mt-1 w-4 h-4 border-border rounded-[2px] text-gold-primary focus:ring-gold-primary/35"
    />
    <label for="gdpr" class="text-[0.8125rem] text-text-secondary leading-relaxed">
      Souhlasím se zpracováním osobních údajů za účelem odpovědi na můj dotaz. Více informací v zásadách ochrany osobních údajů.
    </label>
  </div>

  <Button type="submit" variant="primary">Odeslat zprávu</Button>
</form>
