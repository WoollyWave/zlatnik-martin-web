---
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';
---

<Layout
  title="Stránka nenalezena | Martin Ševr — Zlatnická dílna Praha"
  description="Tato stránka neexistuje. Vraťte se na úvodní stránku."
>
  <section class="relative bg-bg-primary border-b border-border py-28 sm:py-36 lg:py-48 overflow-hidden">
    <div class="radial-overlay"></div>
    <div class="relative max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-14 text-center">
      <span class="label-dot justify-center">Chyba 404</span>
      <h1 class="mt-6">Stránka<br /><em>nenalezena</em></h1>
      <p class="mt-6 text-text-secondary text-[1.0625rem] leading-relaxed max-w-md mx-auto">
        Omlouváme se, tato stránka neexistuje nebo byla přesunuta.
      </p>
      <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
        <Button href="/" variant="primary">Zpět na úvodní stránku</Button>
        <Button href="/kontakt" variant="secondary">Kontaktovat</Button>
      </div>
    </div>
  </section>
</Layout>
