---
import Layout from '../layouts/Layout.astro';
import ProductCard from '../components/ProductCard.astro';
import FilterPills from '../components/FilterPills.astro';
import { products } from '../data/products';

const categories = [...new Set(products.map(p => p.category))];
const filterLabels = ['Vše', ...categories.map(c => {
  const map: Record<string, string> = {
    'prsteny': 'Prsteny',
    'nausnice': 'Náušnice',
    'privesky': 'Přívěsky',
    'retizky': 'Řetízky',
    'sady': 'Sady',
  };
  return map[c] || c;
})];
---

<Layout
  title="Skladem | Martin Ševr — Zlatnická dílna Praha"
  description="Stříbrné šperky s přírodními kameny. Ihned k dispozici. Ruční výroba, certifikované materiály."
>

  <!-- ====== HERO ====== -->
  <section class="relative bg-bg-primary border-b border-border py-20 sm:py-28 lg:py-36 overflow-hidden">
    <div class="radial-overlay"></div>
    <div class="relative max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-14">
      <div class="max-w-3xl" data-anim="up">
        <span class="label-dot">Skladem</span>
        <h1 class="mt-6">
          Hotové <em>šperky</em>
        </h1>
        <p class="mt-6 text-text-secondary text-[1.0625rem] leading-relaxed max-w-xl">
          Ručně vyrobené šperky ihned k dispozici. Každý kus je originál — stříbro, přírodní kameny, certifikované materiály.
        </p>
      </div>
    </div>
  </section>

  <!-- ====== PRODUCTS ====== -->
  <section class="relative bg-bg-primary py-16 sm:py-20 lg:py-24 overflow-hidden">
    <div class="radial-overlay"></div>
    <div class="relative max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-14">

      <FilterPills items={filterLabels} activeIndex={0} />

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-10" id="products-grid">
        {products.map((product) => (
          <ProductCard
            title={product.title}
            material={product.material}
            price={product.price}
            href={`/sperky/${product.slug}`}
            category={product.category}
            image={product.image}
            image2x={product.image2x}
            alt={product.alt}
            description={product.description}
          />
        ))}
      </div>

    </div>
  </section>

</Layout>
