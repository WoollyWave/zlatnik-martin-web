---
import Layout from '../layouts/Layout.astro';
import ProductCard from '../components/ProductCard.astro';
import FilterPills from '../components/FilterPills.astro';
import CTA from '../components/CTA.astro';
import { products } from '../data/products';

const filters = ['Vše', 'Prsteny', 'Náušnice', 'Přívěsky', 'Řetízky', 'Sady'];
---

<Layout
  title="Skladem | Martin Ševr — Zlatnická dílna Praha"
  description="Stříbrné šperky s přírodními kameny. Ihned k dispozici. Ruční výroba, certifikované materiály."
>

  <!-- ====== HEADER + GRID ====== -->
  <section class="relative bg-bg-primary border-b border-border py-16 sm:py-20 lg:py-24 overflow-hidden">
    <div class="radial-overlay"></div>
    <div class="relative max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-14">

      <div class="text-center max-w-2xl mx-auto mb-14" data-anim="up">
        <span class="label-dot justify-center">Skladem</span>
        <h1 class="mt-5">Hotové šperky</h1>
        <p class="mt-4 text-text-secondary">Ručně vyrobené šperky ihned k dispozici. Každý kus je originál.</p>
      </div>

      <FilterPills items={filters} activeIndex={0} />

      <div class="mt-10 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8" data-anim="stagger">
        {products.map((product) => (
          <div data-anim-child>
            <ProductCard
              title={product.title}
              material={product.material}
              price={product.price}
              href={`/sperky/${product.slug}`}
              category={product.category}
              image={product.image}
              image2x={product.image2x}
              alt={product.alt}
            />
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- ====== CTA ====== -->
  <section class="bg-bg-primary relative overflow-hidden py-16 sm:py-20 lg:py-24">
    <div class="radial-overlay"></div>
    <div class="relative max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-14">
      <CTA heading="Nenašli jste, co<br /><em>hledáte</em>?" subheading="Vyrobím šperk přesně podle vaší představy." />
    </div>
  </section>

</Layout>
