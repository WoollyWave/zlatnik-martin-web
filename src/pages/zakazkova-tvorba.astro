---
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';
import FAQ from '../components/FAQ.astro';

const processSteps = [
  {
    number: '01',
    title: 'Konzultace',
    description: 'Setkáme se v dílně nebo si zavoláme. Ukážete mi svou představu — skicu, fotografii, nebo jen slovy. Probereme materiál, časový rámec i rozpočet.',
    image: '/images/zakazkova--proces-01--3d-cad-navrh.webp',
    image2x: '/images/zakazkova--proces-01--3d-cad-navrh@2x.webp',
    alt: '3D CAD návrh šperku',
  },
  {
    number: '02',
    title: 'Návrh',
    description: 'Připravím návrh vašeho šperku. U složitějších kusů vytvořím 3D model nebo voskový prototyp. Nic nevznikne, dokud nebudete souhlasit.',
    image: '/images/zakazkova--proces-02--3d-cad-perspektiva.webp',
    image2x: '/images/zakazkova--proces-02--3d-cad-perspektiva@2x.webp',
    alt: '3D model prstenu — perspektiva',
  },
  {
    number: '03',
    title: 'Výroba',
    description: 'Každý šperk vyrábím ručně ve své dílně. Fotím každý krok — budete vědět, jak váš šperk vzniká. Žádná sériová výroba, žádné kompromisy.',
    image: '/images/zakazkova--proces-03--snubaky-v-ruce-vyroba.webp',
    image2x: '/images/zakazkova--proces-03--snubaky-v-ruce-vyroba@2x.webp',
    alt: 'Ruční výroba snubních prstenů',
  },
  {
    number: '04',
    title: 'Předání',
    description: 'Šperk si můžete vyzvednout osobně v dílně nebo ho pošlu pojištěný zásilkou. Ke každému kusu dostanete certifikát pravosti.',
    image: '/images/zakazkova--proces-04--privesek-J-na-krku-predani.webp',
    image2x: '/images/zakazkova--proces-04--privesek-J-na-krku-predani@2x.webp',
    alt: 'Hotový přívěsek na krku — předání klientce',
  },
];

const materials = [
  {
    title: 'Zlato a stříbro',
    description: 'Pracuji se zlatem 585/1000 i 750/1000 a stříbrem 925/1000. Všechny kovy certifikované, puncované.',
  },
  {
    title: 'Drahé kameny',
    description: 'Diamanty, safíry, rubíny, smaragdy. Každý kámen ručně vybraný od ověřených dodavatelů s certifikátem.',
  },
  {
    title: 'Přírodní kameny',
    description: 'Opály, granáty, ametysty, měsíční kameny, turmalíny. Vyberu kámen, který odpovídá vašemu přání a rozpočtu.',
  },
];

const pricingSilver = [
  { item: 'Jednoduchý prsten', price: 'od 2 500 Kč' },
  { item: 'Prsten s kamenem', price: 'od 3 500 Kč' },
  { item: 'Náušnice (pár)', price: 'od 2 800 Kč' },
  { item: 'Přívěsek', price: 'od 1 800 Kč' },
  { item: 'Náhrdelník', price: 'od 4 500 Kč' },
];

const pricingGold = [
  { item: 'Jednoduchý prsten (585)', price: 'od 8 000 Kč' },
  { item: 'Prsten s kamenem (585)', price: 'od 12 000 Kč' },
  { item: 'Snubní prsteny (pár, 585)', price: 'od 18 000 Kč' },
  { item: 'Náušnice (pár, 585)', price: 'od 9 000 Kč' },
  { item: 'Náhrdelník (585)', price: 'od 15 000 Kč' },
];

const faqItems = [
  {
    question: 'Jak dlouho trvá výroba zakázkového šperku?',
    answer: 'Jednoduchý šperk (prsten, přívěsek) vyrobím během 2–3 týdnů. Složitější kusy s kameny nebo gravurami 4–6 týdnů. U expresních objednávek se domluvíme individuálně.',
  },
  {
    question: 'Kolik stojí zakázkový šperk?',
    answer: 'Cena záleží na materiálu, složitosti a použitých kamenech. Stříbrné šperky začínají od 2 500 Kč, zlaté od 8 000 Kč. Přesnou kalkulaci udělám až po konzultaci.',
  },
  {
    question: 'Můžete opravit nebo upravit existující šperk?',
    answer: 'Ano, opravuji a upravuji šperky — změna velikosti prstenu, výměna kamenu, oprava zapínání. Přineste šperk do dílny a řekneme si, co je možné.',
  },
  {
    question: 'Jak probíhá konzultace?',
    answer: 'Zavolejte nebo napište na WhatsApp. Můžeme se potkat v dílně v Praze 5, nebo vše probereme na dálku — telefonem, emailem či videohovorem.',
  },
  {
    question: 'Poskytuji záruku na své šperky?',
    answer: 'Každý šperk má doživotní záruku na vadu materiálu a zpracování. Běžné opotřebení (poškrábání, patina) není zárukou kryto, ale rád pomůžu s údržbou.',
  },
];
---

<Layout
  title="Zakázková tvorba | Martin Ševr — Zlatnická dílna Praha"
  description="Váš šperk na míru. Pracuji se zlatem, stříbrem a přírodními kameny. Konzultace, návrh, výroba, předání."
>

  <!-- ====== HERO — Scattered Gallery ====== -->
  <section class="relative bg-bg-primary border-b border-border overflow-hidden min-h-0 md:min-h-screen">

    <!-- Scattered images — desktop only -->
    <div class="hidden md:block absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute top-[5%] left-[-3%] w-[28%] max-w-[320px]" data-float="0.3">
        <img src="/images/zakazkova--proces-03--snubaky-v-ruce-vyroba.webp"
          srcset="/images/zakazkova--proces-03--snubaky-v-ruce-vyroba.webp 1x, /images/zakazkova--proces-03--snubaky-v-ruce-vyroba@2x.webp 2x"
          alt="" width="800" height="600" loading="lazy" decoding="async"
          class="w-full h-auto object-cover shadow-[0_8px_30px_rgba(0,0,0,0.08)]" />
      </div>
      <div class="absolute top-[3%] left-[35%] w-[18%] max-w-[220px]" data-float="0.4">
        <img src="/images/zakazkova--proces-01--3d-cad-navrh.webp"
          srcset="/images/zakazkova--proces-01--3d-cad-navrh.webp 1x, /images/zakazkova--proces-01--3d-cad-navrh@2x.webp 2x"
          alt="" width="800" height="600" loading="lazy" decoding="async"
          class="w-full h-auto object-cover shadow-[0_8px_30px_rgba(0,0,0,0.08)]" />
      </div>
      <div class="absolute top-[2%] right-[5%] w-[25%] max-w-[300px]" data-float="0.3">
        <img src="/images/homepage--portfolio-3--snubni-prsteny-zlate.webp"
          srcset="/images/homepage--portfolio-3--snubni-prsteny-zlate.webp 1x, /images/homepage--portfolio-3--snubni-prsteny-zlate@2x.webp 2x"
          alt="" width="800" height="600" loading="lazy" decoding="async"
          class="w-full h-auto object-cover shadow-[0_8px_30px_rgba(0,0,0,0.08)]" />
      </div>
      <div class="absolute top-[40%] left-[-5%] w-[14%] max-w-[160px]" data-float="0.6">
        <img src="/images/zakazkova--materialy--opal-na-dreve.webp"
          srcset="/images/zakazkova--materialy--opal-na-dreve.webp 1x, /images/zakazkova--materialy--opal-na-dreve@2x.webp 2x"
          alt="" width="800" height="600" loading="lazy" decoding="async"
          class="w-full h-auto object-cover shadow-[0_8px_30px_rgba(0,0,0,0.08)]" />
      </div>
      <div class="absolute top-[35%] right-[-2%] w-[22%] max-w-[260px]" data-float="0.5">
        <img src="/images/homepage--portfolio-2--privesek-citrin.webp"
          srcset="/images/homepage--portfolio-2--privesek-citrin.webp 1x, /images/homepage--portfolio-2--privesek-citrin@2x.webp 2x"
          alt="" width="800" height="600" loading="lazy" decoding="async"
          class="w-full h-auto object-cover shadow-[0_8px_30px_rgba(0,0,0,0.08)]" />
      </div>
      <div class="absolute bottom-[8%] left-[8%] w-[22%] max-w-[270px]" data-float="0.7">
        <img src="/images/zakazkova--proces-04--privesek-J-na-krku-predani.webp"
          srcset="/images/zakazkova--proces-04--privesek-J-na-krku-predani.webp 1x, /images/zakazkova--proces-04--privesek-J-na-krku-predani@2x.webp 2x"
          alt="" width="800" height="600" loading="lazy" decoding="async"
          class="w-full h-auto object-cover shadow-[0_8px_30px_rgba(0,0,0,0.08)]" />
      </div>
      <div class="absolute bottom-[3%] right-[25%] w-[20%] max-w-[240px]" data-float="0.6">
        <img src="/images/zakazkova--proces-02--3d-cad-perspektiva.webp"
          srcset="/images/zakazkova--proces-02--3d-cad-perspektiva.webp 1x, /images/zakazkova--proces-02--3d-cad-perspektiva@2x.webp 2x"
          alt="" width="800" height="600" loading="lazy" decoding="async"
          class="w-full h-auto object-cover shadow-[0_8px_30px_rgba(0,0,0,0.08)]" />
      </div>
      <div class="absolute bottom-[5%] right-[2%] w-[18%] max-w-[200px]" data-float="0.8">
        <img src="/images/zakazkova--parallax--tricolor-prsten-na-kovadline.webp"
          srcset="/images/zakazkova--parallax--tricolor-prsten-na-kovadline.webp 1x, /images/zakazkova--parallax--tricolor-prsten-na-kovadline@2x.webp 2x"
          alt="" width="1920" height="1080" loading="lazy" decoding="async"
          class="w-full h-auto object-cover shadow-[0_8px_30px_rgba(0,0,0,0.08)]" />
      </div>
    </div>

    <!-- Centered content -->
    <div class="relative z-10 flex flex-col items-center justify-center text-center px-6 sm:px-8 lg:px-14 py-16 md:py-0 md:min-h-screen">
      <span class="label-dot" data-anim="fade">Zakázková tvorba</span>
      <h1 class="mt-6 max-w-3xl" data-anim="up">
        Váš šperk
        <em>na míru</em>
      </h1>
      <p class="mt-6 text-text-secondary text-[1.0625rem] leading-relaxed max-w-xl" data-anim="up">
        Každý zakázkový šperk začíná rozhovorem. Řekněte mi svůj nápad a já ho proměním v realitu — ručně, v pražské dílně, s materiály, které si společně vybereme.
      </p>
      <div class="mt-10 flex flex-col sm:flex-row gap-4" data-anim="up">
        <Button href="#process" variant="primary">Poptat šperk</Button>
        <Button href="#cenik" variant="secondary">Orientační ceník</Button>
      </div>

      <!-- Mobile only -->
      <div class="md:hidden mt-12 w-full">
        <img src="/images/zakazkova--hero--privesek-quartz-na-krku.webp"
          srcset="/images/zakazkova--hero--privesek-quartz-na-krku.webp 1x, /images/zakazkova--hero--privesek-quartz-na-krku@2x.webp 2x"
          width="1920" height="1080" alt="Zakázková výroba šperků" loading="eager" decoding="async"
          class="w-full h-auto object-cover" />
      </div>
    </div>
  </section>

  <!-- ====== PROCESS — 4 cards grid ====== -->
  <section id="process" class="relative bg-bg-primary border-b border-border py-16 sm:py-20 lg:py-24 overflow-hidden">
    <div class="radial-overlay"></div>
    <div class="relative max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-14">
      <span class="label-dot" data-anim="fade">Proces</span>
      <h2 class="mt-5 max-w-2xl" data-anim="up">Jak vzniká váš šperk</h2>
      <p class="mt-4 text-text-secondary max-w-lg" data-anim="up">Od prvního slova k hotovému kusu.</p>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8 mt-14" data-anim="stagger">
        {processSteps.map((step) => (
          <div data-anim-child class="border border-border p-6 sm:p-8">
            <div class="overflow-hidden mb-6">
              <img
                src={step.image}
                srcset={`${step.image} 1x, ${step.image2x} 2x`}
                width="800" height="600"
                alt={step.alt}
                loading="lazy"
                decoding="async"
                class="w-full h-48 object-cover" data-anim="scale"
              />
            </div>
            <span class="text-[0.75rem] text-text-muted font-sans">{step.number}</span>
            <h3 class="mt-2">{step.title}</h3>
            <p class="mt-2 text-text-secondary text-[0.9375rem] leading-relaxed">{step.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ====== MATERIALS — 2 columns ====== -->
  <section class="relative bg-bg-primary border-b border-border py-16 sm:py-20 lg:py-24">
    <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-14">
      <span class="label-dot" data-anim="fade">Materiály</span>
      <h2 class="mt-5 max-w-2xl" data-anim="up">Certifikované materiály</h2>
      <p class="mt-4 text-text-secondary max-w-lg" data-anim="up">Certifikované kovy a ručně vybrané kameny od ověřených dodavatelů.</p>

      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-start mt-14" data-anim="up">
        <div class="relative overflow-hidden" data-anim="scale">
          <img
            src="/images/zakazkova--materialy--opal-na-dreve.webp"
            srcset="/images/zakazkova--materialy--opal-na-dreve.webp 1x, /images/zakazkova--materialy--opal-na-dreve@2x.webp 2x"
            width="800" height="600"
            alt="Opál na dřevěné podložce — syrový materiál"
            loading="lazy"
            decoding="async"
            class="w-full h-full object-cover grayscale-[15%] sepia-[10%]"
          />
          <div class="absolute inset-2 border border-white/10 pointer-events-none"></div>
        </div>
        <div class="space-y-8">
          {materials.map((mat) => (
            <div>
              <h4>{mat.title}</h4>
              <p class="mt-2 text-text-secondary text-[0.9375rem] leading-relaxed">{mat.description}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ====== PRICING — Stříbro + Zlato side by side ====== -->
  <section id="cenik" class="relative bg-bg-primary border-b border-border py-16 sm:py-20 lg:py-24">
    <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-14">
      <span class="label-dot" data-anim="fade">Ceník</span>
      <h2 class="mt-5" data-anim="up">Orientační ceník</h2>
      <p class="mt-4 text-text-secondary max-w-xl" data-anim="up">Ceny závisí na složitosti, materiálu a kamenech. Přesnou kalkulaci udělám po konzultaci.</p>

      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 mt-14" data-anim="up">
        <!-- Stříbro -->
        <div>
          <h3 class="mb-6">Stříbro 925</h3>
          <div class="border-t border-border">
            {pricingSilver.map((row) => (
              <div class="flex items-center justify-between py-4 border-b border-border">
                <span class="text-text-primary">{row.item}</span>
                <span class="text-text-secondary font-medium whitespace-nowrap ml-4">{row.price}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Zlato -->
        <div>
          <h3 class="mb-6">Zlato 585</h3>
          <div class="border-t border-border">
            {pricingGold.map((row) => (
              <div class="flex items-center justify-between py-4 border-b border-border">
                <span class="text-text-primary">{row.item}</span>
                <span class="text-text-secondary font-medium whitespace-nowrap ml-4">{row.price}</span>
              </div>
            ))}
          </div>
          <p class="mt-4 text-[0.8125rem] text-text-muted">U zlata 750/1000 přičtěte cca 30 %.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ====== FULLWIDTH PARALLAX PHOTO ====== -->
  <section class="relative h-[40vh] sm:h-[50vh] lg:h-[70vh] overflow-hidden" data-parallax>
    <img
      src="/images/zakazkova--parallax--tricolor-prsten-na-kovadline.webp"
      srcset="/images/zakazkova--parallax--tricolor-prsten-na-kovadline.webp 1x, /images/zakazkova--parallax--tricolor-prsten-na-kovadline@2x.webp 2x"
      width="1920" height="1080"
      alt="Detailní záběr zlatnické práce"
      loading="lazy"
      decoding="async"
      class="absolute inset-0 w-full h-[130%] object-cover -top-[15%] object-center sm:object-[center_80%]"
    />
  </section>

  <!-- ====== EXPRESS ====== -->
  <section id="express" class="relative bg-bg-primary border-b border-border py-16 sm:py-20 lg:py-24">
    <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-14">
      <div class="grid lg:grid-cols-[1fr_0.5fr] gap-12 lg:gap-16 items-center" data-anim="up">
        <div>
          <span class="label-dot">Expresní výroba</span>
          <h2 class="mt-5">Potřebujete šperk dřív?</h2>
          <p class="mt-4 text-text-secondary text-[1.0625rem] leading-relaxed max-w-xl">
            Narozeniny, výročí, zásnuby — někdy se termín blíží rychleji, než čekáte. U jednodušších šperků zvládnu expresní výrobu do 5 pracovních dní. Zavolejte a domluvíme se.
          </p>
          <div class="mt-8 flex flex-col sm:flex-row gap-4">
            <Button href="tel:+420774598181" variant="primary">Zavolat</Button>
            <Button href="https://wa.me/420774598181" variant="secondary">Napsat na WhatsApp</Button>
          </div>
        </div>
        <div class="hidden lg:block" data-anim="scale">
          <img
            src="/images/zakazkova--express--prsten-safir.webp"
            srcset="/images/zakazkova--express--prsten-safir.webp 1x, /images/zakazkova--express--prsten-safir@2x.webp 2x"
            width="600" height="600"
            alt="Prsten s růžovým safírem — expresní výroba"
            loading="lazy"
            decoding="async"
            class="w-full h-auto object-cover"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ====== FAQ — bg-secondary ====== -->
  <section class="relative bg-bg-primary py-16 sm:py-20 lg:py-24 overflow-hidden">
    <div class="radial-overlay"></div>
    <div class="relative max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-14">
      <span class="label-dot" data-anim="fade">Časté otázky</span>
      <h2 class="mt-5 mb-12" data-anim="up">Časté otázky</h2>
      <FAQ items={faqItems} />
    </div>
  </section>


</Layout>
