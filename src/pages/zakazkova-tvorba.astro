---
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';
import FAQ from '../components/FAQ.astro';
import CTA from '../components/CTA.astro';

const processSteps = [
  {
    number: '01',
    title: 'Konzultace',
    description: 'Setkáme se v dílně nebo si zavoláme. Ukážete mi svou představu — skicu, fotografii, nebo jen slovy. Probereme materiál, časový rámec i rozpočet.',
    image: '/images/zakazkova--proces-01--3d-cad-navrh.webp',
    image2x: '/images/zakazkova--proces-01--3d-cad-navrh@2x.webp',
    alt: '3D CAD návrh šperku',
  },
  {
    number: '02',
    title: 'Návrh',
    description: 'Připravím návrh vašeho šperku. U složitějších kusů vytvořím 3D model nebo voskový prototyp. Nic nevznikne, dokud nebudete souhlasit.',
    image: '/images/zakazkova--proces-02--3d-cad-perspektiva.webp',
    image2x: '/images/zakazkova--proces-02--3d-cad-perspektiva@2x.webp',
    alt: '3D model prstenu — perspektiva',
  },
  {
    number: '03',
    title: 'Výroba',
    description: 'Každý šperk vyrábím ručně ve své dílně. Fotím každý krok — budete vědět, jak váš šperk vzniká. Žádná sériová výroba, žádné kompromisy.',
    image: '/images/zakazkova--proces-03--snubaky-v-ruce-vyroba.webp',
    image2x: '/images/zakazkova--proces-03--snubaky-v-ruce-vyroba@2x.webp',
    alt: 'Ruční výroba snubních prstenů',
  },
  {
    number: '04',
    title: 'Předání',
    description: 'Šperk si můžete vyzvednout osobně v dílně nebo ho pošlu pojištěný zásilkou. Ke každému kusu dostanete certifikát pravosti.',
    image: '/images/zakazkova--proces-04--privesek-J-na-krku-predani.webp',
    image2x: '/images/zakazkova--proces-04--privesek-J-na-krku-predani@2x.webp',
    alt: 'Hotový přívěsek na krku — předání klientce',
  },
];

const materials = [
  {
    title: 'Zlato a stříbro',
    description: 'Pracuji se zlatem 585/1000 i 750/1000 a stříbrem 925/1000. Všechny kovy certifikované, puncované.',
  },
  {
    title: 'Drahé kameny',
    description: 'Diamanty, safíry, rubíny, smaragdy. Každý kámen ručně vybraný od ověřených dodavatelů s certifikátem.',
  },
  {
    title: 'Přírodní kameny',
    description: 'Opály, granáty, ametysty, měsíční kameny, turmalíny. Vyberu kámen, který odpovídá vašemu přání a rozpočtu.',
  },
];

const pricingSilver = [
  { item: 'Jednoduchý prsten', price: 'od 2 500 Kč' },
  { item: 'Prsten s kamenem', price: 'od 3 500 Kč' },
  { item: 'Náušnice (pár)', price: 'od 2 800 Kč' },
  { item: 'Přívěsek', price: 'od 1 800 Kč' },
  { item: 'Náhrdelník', price: 'od 4 500 Kč' },
];

const pricingGold = [
  { item: 'Jednoduchý prsten (585)', price: 'od 8 000 Kč' },
  { item: 'Prsten s kamenem (585)', price: 'od 12 000 Kč' },
  { item: 'Snubní prsteny (pár, 585)', price: 'od 18 000 Kč' },
  { item: 'Náušnice (pár, 585)', price: 'od 9 000 Kč' },
  { item: 'Náhrdelník (585)', price: 'od 15 000 Kč' },
];

const faqItems = [
  {
    question: 'Jak dlouho trvá výroba zakázkového šperku?',
    answer: 'Jednoduchý šperk (prsten, přívěsek) vyrobím během 2–3 týdnů. Složitější kusy s kameny nebo gravurami 4–6 týdnů. U expresních objednávek se domluvíme individuálně.',
  },
  {
    question: 'Kolik stojí zakázkový šperk?',
    answer: 'Cena záleží na materiálu, složitosti a použitých kamenech. Stříbrné šperky začínají od 2 500 Kč, zlaté od 8 000 Kč. Přesnou kalkulaci udělám až po konzultaci.',
  },
  {
    question: 'Můžete opravit nebo upravit existující šperk?',
    answer: 'Ano, opravuji a upravuji šperky — změna velikosti prstenu, výměna kamenu, oprava zapínání. Přineste šperk do dílny a řekneme si, co je možné.',
  },
  {
    question: 'Jak probíhá konzultace?',
    answer: 'Zavolejte nebo napište na WhatsApp. Můžeme se potkat v dílně v Praze 5, nebo vše probereme na dálku — telefonem, emailem či videohovorem.',
  },
  {
    question: 'Poskytuji záruku na své šperky?',
    answer: 'Každý šperk má doživotní záruku na vadu materiálu a zpracování. Běžné opotřebení (poškrábání, patina) není zárukou kryto, ale rád pomůžu s údržbou.',
  },
];
---

<Layout
  title="Zakázková tvorba | Martin Ševr — Zlatnická dílna Praha"
  description="Váš šperk na míru. Pracuji se zlatem, stříbrem a přírodními kameny. Konzultace, návrh, výroba, předání."
>

  <!-- ====== HERO — Scattered Gallery (Relume Header 142) ====== -->
  <section class="relative bg-bg-primary overflow-hidden" style="min-height: 100vh;">

    <!-- Scattered images — desktop only -->
    <div class="hidden md:block absolute inset-0 pointer-events-none" aria-hidden="true">

      <!-- Top left — velká -->
      <div class="absolute top-[5%] left-[-3%] w-[28%] max-w-[320px]" data-float="0.3">
        <img src="/images/zakazkova--proces-03--snubaky-v-ruce-vyroba.webp"
          srcset="/images/zakazkova--proces-03--snubaky-v-ruce-vyroba.webp 1x, /images/zakazkova--proces-03--snubaky-v-ruce-vyroba@2x.webp 2x"
          alt="" width="800" height="600" loading="eager" decoding="async"
          class="w-full h-auto object-cover shadow-[0_8px_30px_rgba(0,0,0,0.08)]" />
      </div>

      <!-- Top center — střední -->
      <div class="absolute top-[3%] left-[35%] w-[18%] max-w-[220px]" data-float="0.4">
        <img src="/images/zakazkova--proces-01--3d-cad-navrh.webp"
          srcset="/images/zakazkova--proces-01--3d-cad-navrh.webp 1x, /images/zakazkova--proces-01--3d-cad-navrh@2x.webp 2x"
          alt="" width="800" height="600" loading="eager" decoding="async"
          class="w-full h-auto object-cover shadow-[0_8px_30px_rgba(0,0,0,0.08)]" />
      </div>

      <!-- Top right — velká -->
      <div class="absolute top-[2%] right-[5%] w-[25%] max-w-[300px]" data-float="0.3">
        <img src="/images/homepage--portfolio-3--snubni-prsteny-zlate.webp"
          srcset="/images/homepage--portfolio-3--snubni-prsteny-zlate.webp 1x, /images/homepage--portfolio-3--snubni-prsteny-zlate@2x.webp 2x"
          alt="" width="800" height="600" loading="eager" decoding="async"
          class="w-full h-auto object-cover shadow-[0_8px_30px_rgba(0,0,0,0.08)]" />
      </div>

      <!-- Middle left — vysoká úzká -->
      <div class="absolute top-[40%] left-[-5%] w-[14%] max-w-[160px]" data-float="0.6">
        <img src="/images/zakazkova--materialy--opal-na-dreve.webp"
          srcset="/images/zakazkova--materialy--opal-na-dreve.webp 1x, /images/zakazkova--materialy--opal-na-dreve@2x.webp 2x"
          alt="" width="800" height="600" loading="eager" decoding="async"
          class="w-full h-auto object-cover shadow-[0_8px_30px_rgba(0,0,0,0.08)]" />
      </div>

      <!-- Middle right — střední -->
      <div class="absolute top-[35%] right-[-2%] w-[22%] max-w-[260px]" data-float="0.5">
        <img src="/images/homepage--portfolio-2--privesek-citrin.webp"
          srcset="/images/homepage--portfolio-2--privesek-citrin.webp 1x, /images/homepage--portfolio-2--privesek-citrin@2x.webp 2x"
          alt="" width="800" height="600" loading="eager" decoding="async"
          class="w-full h-auto object-cover shadow-[0_8px_30px_rgba(0,0,0,0.08)]" />
      </div>

      <!-- Bottom left — střední -->
      <div class="absolute bottom-[8%] left-[8%] w-[22%] max-w-[270px]" data-float="0.7">
        <img src="/images/zakazkova--proces-04--privesek-J-na-krku-predani.webp"
          srcset="/images/zakazkova--proces-04--privesek-J-na-krku-predani.webp 1x, /images/zakazkova--proces-04--privesek-J-na-krku-predani@2x.webp 2x"
          alt="" width="800" height="600" loading="eager" decoding="async"
          class="w-full h-auto object-cover shadow-[0_8px_30px_rgba(0,0,0,0.08)]" />
      </div>

      <!-- Bottom center-right — velká -->
      <div class="absolute bottom-[3%] right-[25%] w-[20%] max-w-[240px]" data-float="0.6">
        <img src="/images/zakazkova--proces-02--3d-cad-perspektiva.webp"
          srcset="/images/zakazkova--proces-02--3d-cad-perspektiva.webp 1x, /images/zakazkova--proces-02--3d-cad-perspektiva@2x.webp 2x"
          alt="" width="800" height="600" loading="eager" decoding="async"
          class="w-full h-auto object-cover shadow-[0_8px_30px_rgba(0,0,0,0.08)]" />
      </div>

      <!-- Bottom right — malá -->
      <div class="absolute bottom-[5%] right-[2%] w-[18%] max-w-[200px]" data-float="0.8">
        <img src="/images/zakazkova--parallax--tricolor-prsten-na-kovadline.webp"
          srcset="/images/zakazkova--parallax--tricolor-prsten-na-kovadline.webp 1x, /images/zakazkova--parallax--tricolor-prsten-na-kovadline@2x.webp 2x"
          alt="" width="1920" height="1080" loading="eager" decoding="async"
          class="w-full h-auto object-cover shadow-[0_8px_30px_rgba(0,0,0,0.08)]" />
      </div>

    </div>

    <!-- Centered content — above images -->
    <div class="relative z-10 flex flex-col items-center justify-center text-center px-5 md:px-8 py-20 md:py-0" style="min-height: 100vh;">
      <h1 class="max-w-3xl" data-animate="up">
        Váš šperk
        <em class="italic text-gold-deep" style="font-variation-settings: 'WONK' 1, 'SOFT' 0, 'opsz' 144; font-weight: 300;">na míru</em>
      </h1>
      <p class="mt-6 text-text-secondary text-[1.0625rem] leading-relaxed max-w-xl" data-animate="up">
        Každý zakázkový šperk začíná rozhovorem. Řekněte mi svůj nápad a já ho proměním v realitu — ručně, v pražské dílně, s materiály, které si společně vybereme.
      </p>
      <div class="mt-10 flex flex-col sm:flex-row gap-4" data-animate="up">
        <a href="#process" class="inline-flex items-center justify-center font-sans font-medium transition-colors duration-300 cursor-pointer bg-text-primary text-[0.9375rem] px-8 py-4 hover:bg-gold-deep" style="color: #FAFBF8;">Poptat šperk</a>
        <a href="#cenik" class="inline-flex items-center justify-center font-sans font-medium transition-colors duration-300 cursor-pointer border border-text-primary/25 text-text-primary bg-transparent text-[0.9375rem] px-8 py-4 hover:border-text-primary/50 hover:bg-hover-bg">Orientační ceník</a>
      </div>

      <!-- Mobile only — single hero photo -->
      <div class="md:hidden mt-12 w-full">
        <img src="/images/zakazkova--hero--privesek-quartz-na-krku.webp"
          srcset="/images/zakazkova--hero--privesek-quartz-na-krku.webp 1x, /images/zakazkova--hero--privesek-quartz-na-krku@2x.webp 2x"
          width="1920" height="1080" alt="Zakázková výroba šperků" loading="eager" decoding="async"
          class="w-full h-auto object-cover" />
      </div>
    </div>

  </section>

  <!-- ====== PROCESS — Timeline 21 ====== -->
  <section id="process" class="bg-bg-primary border-t border-divider py-16 md:py-24 overflow-hidden">
    <div class="max-w-[1400px] mx-auto px-5 md:px-8">

      <!-- Header -->
      <div class="mb-16 md:mb-20" data-animate="up">
        <div class="flex items-center gap-2 mb-4">
          <span class="w-1.5 h-1.5 rounded-full bg-gold-primary"></span>
          <span class="text-[0.6875rem] uppercase tracking-[0.15em] font-medium text-text-primary">Proces</span>
        </div>
        <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6">
          <div>
            <h2>Jak vzniká váš šperk</h2>
            <p class="mt-3 text-text-secondary text-[1.0625rem] leading-relaxed max-w-lg">
              Od prvního slova k hotovému kusu. Čtyři kroky, jeden cíl.
            </p>
          </div>
          <div class="flex items-center gap-3 flex-shrink-0">
            <button id="tl-prev" class="w-10 h-10 border border-text-primary/20 flex items-center justify-center hover:bg-hover-bg transition-colors duration-200 cursor-pointer" aria-label="Předchozí">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" /></svg>
            </button>
            <button id="tl-next" class="w-10 h-10 border border-text-primary/20 flex items-center justify-center hover:bg-hover-bg transition-colors duration-200 cursor-pointer" aria-label="Další">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" /></svg>
            </button>
          </div>
        </div>
      </div>

      <!-- Timeline horizontal scroll -->
      <div id="tl-scroll" class="flex overflow-x-auto scroll-smooth gap-0 pb-4 cursor-grab" style="scrollbar-width: none; -ms-overflow-style: none;">
        <style>#tl-scroll::-webkit-scrollbar{display:none}</style>

        <!-- KROK 01 — foto nahoře, text dole -->
        <div class="flex-shrink-0 w-[260px] md:w-[300px]">
          <div class="h-[180px] md:h-[240px] mb-4 overflow-hidden">
            <img src="/images/zakazkova--proces-01--3d-cad-navrh.webp" srcset="/images/zakazkova--proces-01--3d-cad-navrh.webp 1x, /images/zakazkova--proces-01--3d-cad-navrh@2x.webp 2x" alt="Konzultace" width="800" height="600" loading="lazy" decoding="async" class="w-full h-full object-cover" />
          </div>
          <div class="flex items-center"><span class="w-3 h-3 rounded-full bg-text-primary flex-shrink-0 z-10"></span><span class="h-[2px] bg-text-primary flex-grow"></span></div>
          <div class="mt-4">
            <span class="font-serif text-[1.5rem] font-light text-text-primary">01</span>
            <p class="mt-1 text-text-secondary text-[0.9375rem] leading-relaxed pr-6">Řeknete mi, co si představujete. Já se ptám na detaily.</p>
          </div>
        </div>

        <!-- KROK 02 — text nahoře, foto dole -->
        <div class="flex-shrink-0 w-[260px] md:w-[300px]">
          <div class="h-[180px] md:h-[240px] mb-4 flex flex-col justify-end">
            <span class="font-serif text-[1.5rem] font-light text-text-primary">02</span>
            <p class="mt-1 text-text-secondary text-[0.9375rem] leading-relaxed pr-6">Kreslím a modeluji, dokud to není přesně ono.</p>
          </div>
          <div class="flex items-center"><span class="w-3 h-3 rounded-full bg-text-primary flex-shrink-0 z-10"></span><span class="h-[2px] bg-text-primary flex-grow"></span></div>
          <div class="mt-4 h-[180px] md:h-[280px] overflow-hidden">
            <img src="/images/zakazkova--proces-02--3d-cad-perspektiva.webp" srcset="/images/zakazkova--proces-02--3d-cad-perspektiva.webp 1x, /images/zakazkova--proces-02--3d-cad-perspektiva@2x.webp 2x" alt="Návrh" width="800" height="600" loading="lazy" decoding="async" class="w-full h-full object-cover" />
          </div>
        </div>

        <!-- KROK 03 — foto nahoře, text dole (větší foto) -->
        <div class="flex-shrink-0 w-[280px] md:w-[340px]">
          <div class="h-[200px] md:h-[280px] mb-4 overflow-hidden">
            <img src="/images/zakazkova--proces-03--snubaky-v-ruce-vyroba.webp" srcset="/images/zakazkova--proces-03--snubaky-v-ruce-vyroba.webp 1x, /images/zakazkova--proces-03--snubaky-v-ruce-vyroba@2x.webp 2x" alt="Výroba" width="800" height="600" loading="lazy" decoding="async" class="w-full h-full object-cover" />
          </div>
          <div class="flex items-center"><span class="w-3 h-3 rounded-full bg-text-primary flex-shrink-0 z-10"></span><span class="h-[2px] bg-text-primary flex-grow"></span></div>
          <div class="mt-4">
            <span class="font-serif text-[1.5rem] font-light text-text-primary">03</span>
            <p class="mt-1 text-text-secondary text-[0.9375rem] leading-relaxed pr-6">Šperk vzniká v mých rukou. Každý krok fotím.</p>
          </div>
        </div>

        <!-- KROK 04 — text nahoře, foto dole -->
        <div class="flex-shrink-0 w-[260px] md:w-[300px]">
          <div class="h-[200px] md:h-[280px] mb-4 flex flex-col justify-end">
            <span class="font-serif text-[1.5rem] font-light text-text-primary">04</span>
            <p class="mt-1 text-text-secondary text-[0.9375rem] leading-relaxed pr-6">Máte ho v rukou a víte, že je to přesně to, co jste chtěli.</p>
          </div>
          <div class="flex items-center"><span class="w-3 h-3 rounded-full bg-text-primary flex-shrink-0 z-10"></span><span class="h-[2px] bg-text-primary flex-grow"></span></div>
          <div class="mt-4 h-[180px] md:h-[260px] overflow-hidden">
            <img src="/images/zakazkova--proces-04--privesek-J-na-krku-predani.webp" srcset="/images/zakazkova--proces-04--privesek-J-na-krku-predani.webp 1x, /images/zakazkova--proces-04--privesek-J-na-krku-predani@2x.webp 2x" alt="Předání" width="800" height="600" loading="lazy" decoding="async" class="w-full h-full object-cover" />
          </div>
        </div>

        <!-- End labels -->
        <div class="flex-shrink-0 w-[200px]">
          <div class="h-[200px] md:h-[280px] mb-4"></div>
          <div class="flex items-center"><span class="w-3 h-3 rounded-full bg-text-primary flex-shrink-0 z-10"></span></div>
          <div class="mt-4 space-y-2">
            <p class="font-medium text-text-primary">Konzultace</p>
            <p class="text-[0.9375rem] text-text-secondary">Návrh</p>
            <p class="text-[0.9375rem] text-text-secondary">Výroba</p>
            <p class="text-[0.9375rem] text-text-secondary">Předání</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <script>
    const track = document.getElementById('tl-scroll');
    const prev = document.getElementById('tl-prev');
    const next = document.getElementById('tl-next');
    if (track && prev && next) {
      const step = 320;
      next.addEventListener('click', () => track.scrollBy({ left: step, behavior: 'smooth' }));
      prev.addEventListener('click', () => track.scrollBy({ left: -step, behavior: 'smooth' }));
      let down = false, sx = 0, sl = 0;
      track.addEventListener('mousedown', (e) => { down = true; track.style.cursor = 'grabbing'; sx = e.pageX - track.offsetLeft; sl = track.scrollLeft; });
      track.addEventListener('mouseleave', () => { down = false; track.style.cursor = 'grab'; });
      track.addEventListener('mouseup', () => { down = false; track.style.cursor = 'grab'; });
      track.addEventListener('mousemove', (e) => { if (!down) return; e.preventDefault(); track.scrollLeft = sl - ((e.pageX - track.offsetLeft) - sx) * 1.5; });
    }
  </script>

  <!-- ====== MATERIALS — Section Label ====== -->
  <section class="bg-bg-primary border-t border-divider py-16 md:py-24">
    <div class="max-w-[1400px] mx-auto px-5 md:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-[280px_1fr] gap-12 lg:gap-20">

        <!-- Sidebar label -->
        <div>
          <div class="flex items-center gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-gold-primary"></span>
            <span class="text-[0.6875rem] uppercase tracking-[0.15em] font-medium text-text-primary">Materiály</span>
          </div>
          <p class="text-[0.875rem] text-text-muted leading-relaxed mt-4 max-w-[240px]">
            Certifikované kovy a ručně vybrané kameny od ověřených dodavatelů.
          </p>
        </div>

        <!-- Content -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-start" data-animate="up">
          <div>
            <img
              src="/images/zakazkova--materialy--opal-na-dreve.webp"
              srcset="/images/zakazkova--materialy--opal-na-dreve.webp 1x, /images/zakazkova--materialy--opal-na-dreve@2x.webp 2x"
              width="800" height="600"
              alt="Opál na dřevěné podložce — syrový materiál"
              loading="lazy"
              decoding="async"
              class="w-full h-full object-cover"
            />
          </div>
          <div class="space-y-8">
            {materials.map((mat) => (
              <div>
                <h4>{mat.title}</h4>
                <p class="mt-2 text-text-secondary text-[0.9375rem] leading-relaxed">{mat.description}</p>
              </div>
            ))}
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ====== PRICING STŘÍBRO — Section Label ====== -->
  <section id="cenik" class="bg-bg-primary border-t border-divider py-16 md:py-24">
    <div class="max-w-[1400px] mx-auto px-5 md:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-[280px_1fr] gap-12 lg:gap-20">

        <!-- Sidebar label -->
        <div>
          <div class="flex items-center gap-2">
