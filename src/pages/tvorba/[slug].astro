---
import Layout from '../../layouts/Layout.astro';
import Button from '../../components/Button.astro';
import ImagePlaceholder from '../../components/ImagePlaceholder.astro';
import CTA from '../../components/CTA.astro';
import { portfolioItems, type PortfolioItem } from '../../data/portfolio';

export function getStaticPaths() {
  return portfolioItems.map((item) => ({
    params: { slug: item.slug },
    props: { item },
  }));
}

interface Props {
  item: PortfolioItem;
}

const { item } = Astro.props;
---

<Layout
  title={`${item.title} | Portfolio — Martin Ševr`}
  description={item.description}
>
  <!-- ====== HERO PHOTO ====== -->
  <section class="border-b border-border">
    {item.heroImage ? (
      <img
        src={item.heroImage}
        srcset={`${item.heroImage} 1x, ${item.heroImage2x} 2x`}
        width="1920" height="1080"
        alt={item.alt}
        loading="eager"
        decoding="async"
        class="w-full max-h-[70vh] object-cover"
      />
    ) : item.image ? (
      <img
        src={item.image}
        srcset={`${item.image} 1x, ${item.image2x} 2x`}
        width="800" height="600"
        alt={item.alt}
        loading="eager"
        decoding="async"
        class="w-full max-h-[70vh] object-cover"
      />
    ) : (
      <ImagePlaceholder aspect="16/9" alt={item.title} class="w-full max-h-[70vh] object-cover" />
    )}
  </section>

  <!-- ====== INFO ====== -->
  <section class="bg-bg-primary border-b border-border py-16 sm:py-20 lg:py-24">
    <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-14">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-20">
        <!-- Left — meta -->
        <div data-anim="up">
          <a href="/portfolio" class="inline-flex items-center text-[0.8125rem] text-text-muted hover:text-text-primary transition-colors duration-200 mb-6 uppercase tracking-[0.1em]">
            &larr;&nbsp;Zpět na Portfolio
          </a>
          <div class="flex flex-wrap gap-3 mt-4">
            {item.tags.map((tag) => (
              <span class="text-[0.6875rem] uppercase tracking-wider text-text-muted font-sans border border-border px-3 py-1.5">
                {tag}
              </span>
            ))}
          </div>
          <div class="mt-3 text-[0.875rem] text-text-muted">{item.material}</div>
        </div>

        <!-- Right — content -->
        <div data-anim="up">
          <h1>{item.title}</h1>
          <p class="mt-6 text-text-secondary text-[1.0625rem] leading-relaxed max-w-2xl">
            {item.fullDescription}
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ====== PROCESS GALLERY ====== -->
  <section class="bg-bg-primary border-b border-border py-16 sm:py-20 lg:py-24">
    <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-14">
      <span class="label-dot" data-anim="fade">Proces vzniku</span>
      <p class="text-[0.875rem] text-text-muted leading-relaxed mt-4 max-w-[240px]">
        Od prvního náčrtu po finální lesk.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-10" data-anim="stagger">
        {item.processImages && item.processImages.length > 0 ? (
          item.processImages.map((img) => (
            <div data-anim-child class="relative overflow-hidden">
              <img
                src={img.src}
                srcset={`${img.src} 1x, ${img.src2x} 2x`}
                width="800" height="600"
                alt={img.alt}
                loading="lazy"
                decoding="async"
                class="w-full h-full object-cover grayscale-[15%] sepia-[10%]"
              />
              <div class="absolute inset-2 border border-white/10 pointer-events-none"></div>
              <p class="mt-3 text-[0.8125rem] text-text-muted">{img.alt}</p>
            </div>
          ))
        ) : (
          <>
            <div data-anim-child>
              <ImagePlaceholder aspect="4/3" alt={`${item.title} — návrh`} class="w-full" />
              <p class="mt-3 text-[0.8125rem] text-text-muted">Návrh</p>
            </div>
            <div data-anim-child>
              <ImagePlaceholder aspect="4/3" alt={`${item.title} — výroba`} class="w-full" />
              <p class="mt-3 text-[0.8125rem] text-text-muted">Výroba</p>
            </div>
            <div data-anim-child>
              <ImagePlaceholder aspect="4/3" alt={`${item.title} — hotový kus`} class="w-full" />
              <p class="mt-3 text-[0.8125rem] text-text-muted">Hotový kus</p>
            </div>
          </>
        )}
      </div>
    </div>
  </section>

  <!-- ====== CTA ====== -->
  <section class="bg-bg-secondary relative overflow-hidden py-16 sm:py-20 lg:py-24">
    <div class="radial-overlay"></div>
    <div class="relative max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-14">
      <CTA heading="Chcete podobný šperk<br />na <em>míru</em>?" subheading="Zavolejte a probereme vaši představu." />
    </div>
  </section>

</Layout>
