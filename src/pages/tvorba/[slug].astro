---
import Layout from '../../layouts/Layout.astro';
import Button from '../../components/Button.astro';
import ImagePlaceholder from '../../components/ImagePlaceholder.astro';
import CTA from '../../components/CTA.astro';
import { portfolioItems, type PortfolioItem } from '../../data/portfolio';

export function getStaticPaths() {
  return portfolioItems.map((item) => ({
    params: { slug: item.slug },
    props: { item },
  }));
}

interface Props {
  item: PortfolioItem;
}

const { item } = Astro.props;
---

<Layout
  title={`${item.title} | Portfolio — Martin Ševr`}
  description={item.description}
>
  <!-- ====== HERO PHOTO ====== -->
  <section>
    {item.heroImage ? (
      <img
        src={item.heroImage}
        srcset={`${item.heroImage} 1x, ${item.heroImage2x} 2x`}
        width="1920" height="1080"
        alt={item.alt}
        loading="eager"
        decoding="async"
        class="w-full max-h-[70vh] object-cover"
      />
    ) : item.image ? (
      <img
        src={item.image}
        srcset={`${item.image} 1x, ${item.image2x} 2x`}
        width="800" height="600"
        alt={item.alt}
        loading="eager"
        decoding="async"
        class="w-full max-h-[70vh] object-cover"
      />
    ) : (
      <ImagePlaceholder aspect="16/9" alt={item.title} class="w-full max-h-[70vh] object-cover" />
    )}
  </section>

  <!-- ====== INFO — Section Label ====== -->
  <section class="bg-bg-primary py-16 md:py-24">
    <div class="max-w-[1400px] mx-auto px-8">
      <div class="grid grid-cols-1 lg:grid-cols-[280px_1fr] gap-12 lg:gap-20">

        <!-- Sidebar -->
        <div>
          <a href="/portfolio" class="inline-flex items-center text-[0.8125rem] text-text-muted hover:text-text-primary transition-colors duration-200 mb-6 uppercase tracking-[0.1em]">
            &larr;&nbsp;Zpět na Portfolio
          </a>
          <div class="flex flex-wrap gap-3 mt-4">
            {item.tags.map((tag) => (
              <span class="text-[0.75rem] font-medium uppercase tracking-wider text-text-muted">
                {tag}
              </span>
            ))}
          </div>
          <div class="mt-2 text-[0.875rem] text-text-muted">{item.material}</div>
        </div>

        <!-- Content -->
        <div data-animate="up">
          <h1>{item.title}</h1>
          <p class="mt-6 text-text-secondary text-[1.0625rem] leading-relaxed max-w-2xl">
            {item.fullDescription}
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- ====== PROCESS GALLERY — Section Label ====== -->
  <section class="bg-bg-primary border-t border-divider py-16 md:py-24">
    <div class="max-w-[1400px] mx-auto px-8">
      <div class="grid grid-cols-1 lg:grid-cols-[280px_1fr] gap-12 lg:gap-20">

        <!-- Sidebar label -->
        <div>
          <div class="flex items-center gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-gold-primary"></span>
            <span class="text-[0.6875rem] uppercase tracking-[0.15em] font-medium text-text-primary">Proces vzniku</span>
          </div>
          <p class="text-[0.875rem] text-text-muted leading-relaxed mt-4 max-w-[240px]">
            Od prvního náčrtu po finální lesk.
          </p>
        </div>

        <!-- Gallery -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6" data-animate="up">
          {item.processImages && item.processImages.length > 0 ? (
            item.processImages.map((img) => (
              <div>
                <img
                  src={img.src}
                  srcset={`${img.src} 1x, ${img.src2x} 2x`}
                  width="800" height="600"
                  alt={img.alt}
                  loading="lazy"
                  decoding="async"
                  class="w-full h-full object-cover"
                />
                <p class="mt-3 text-[0.8125rem] text-text-muted">{img.alt}</p>
              </div>
            ))
          ) : (
            <>
              <div>
                <ImagePlaceholder aspect="4/3" alt={`${item.title} — návrh`} class="w-full" />
                <p class="mt-3 text-[0.8125rem] text-text-muted">Návrh</p>
              </div>
              <div>
                <ImagePlaceholder aspect="4/3" alt={`${item.title} — výroba`} class="w-full" />
                <p class="mt-3 text-[0.8125rem] text-text-muted">Výroba</p>
              </div>
              <div>
                <ImagePlaceholder aspect="4/3" alt={`${item.title} — hotový kus`} class="w-full" />
                <p class="mt-3 text-[0.8125rem] text-text-muted">Hotový kus</p>
              </div>
            </>
          )}
        </div>

      </div>
    </div>
  </section>

  <!-- ====== CTA ====== -->
  <CTA
    heading="Chcete podobný šperk na míru"
    subheading="Každý šperk v portfoliu začal jednoduchým nápadem. Řekněte mi ten svůj."
  />

</Layout>
