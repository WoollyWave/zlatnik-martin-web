---
import Layout from '../../layouts/Layout.astro';
import Button from '../../components/Button.astro';
import ProductCard from '../../components/ProductCard.astro';
import { products, type Product } from '../../data/products';

export function getStaticPaths() {
  return products.map((product) => ({
    params: { slug: product.slug },
    props: { product },
  }));
}

interface Props {
  product: Product;
}

const { product } = Astro.props;
const otherProducts = products.filter((p) => p.slug !== product.slug).slice(0, 2);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": product.title,
  "description": product.description,
  "image": `https://zlatnikmartin.cz${product.image}`,
  "offers": {
    "@type": "Offer",
    "price": product.price.replace(/[^\d]/g, ''),
    "priceCurrency": "CZK",
    "availability": "https://schema.org/InStock",
    "seller": {
      "@type": "LocalBusiness",
      "name": "Martin Ševr — Zlatnická dílna"
    }
  },
  "material": product.material,
  "brand": {
    "@type": "Brand",
    "name": "Martin Ševr"
  }
};
---

<Layout
  title={`${product.title} | Martin Ševr — Zlatnická dílna`}
  description={product.description}
  jsonLd={jsonLd}
>

  <!-- ====== HERO — Split: info left + photo right ====== -->
  <section class="relative bg-bg-primary border-b border-border overflow-hidden">
    <div class="radial-overlay"></div>
    <div class="relative max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-14">
      <div class="grid lg:grid-cols-[0.85fr_1.15fr] gap-10 lg:gap-16 items-center py-16 lg:py-24">

        <!-- Left — info -->
        <div data-anim="up">
          <a href="/skladem" class="inline-flex items-center gap-2 text-[11px] text-text-muted hover:text-gold-deep transition-colors duration-200 uppercase tracking-[0.15em] font-sans font-medium">
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" /></svg>
            Zpět na Skladem
          </a>

          <h1 class="mt-8">{product.title}</h1>

          <!-- Price -->
          <p class="mt-4 font-serif text-[1.5rem] text-gold-deep">{product.price}</p>

          <p class="mt-6 text-text-secondary text-[1.0625rem] leading-[1.8] max-w-lg">
            {product.description}
          </p>

          <!-- Meta -->
          <div class="mt-10 pt-8 border-t border-border grid grid-cols-2 gap-6">
            <div>
              <span class="text-[10px] uppercase tracking-[0.16em] font-medium text-text-muted font-sans">Materiál</span>
              <p class="text-[13px] text-text-primary mt-1 font-sans">{product.material}</p>
            </div>
            <div>
              <span class="text-[10px] uppercase tracking-[0.16em] font-medium text-text-muted font-sans">Dostupnost</span>
              <p class="text-[13px] text-text-primary mt-1 font-sans flex items-center gap-2">
                <span class="w-1.5 h-1.5 rounded-full bg-success"></span>
                Skladem — ihned k odběru
              </p>
            </div>
          </div>

          <!-- CTA -->
          <div class="mt-8 flex flex-col sm:flex-row gap-4">
            <Button href="/kontakt" variant="primary">Chci tento šperk</Button>
            <Button href="https://wa.me/420774598181" variant="secondary">Napsat na WhatsApp</Button>
          </div>

          <p class="mt-4 text-[0.8125rem] text-text-muted">
            Osobní vyzvednutí v dílně nebo pojištěná zásilka po celé ČR.
          </p>
        </div>

        <!-- Right — main photo -->
        <div class="relative order-first lg:order-none" data-anim="scale">
          {product.image && (
            <div class="relative overflow-hidden aspect-[1/1]">
              <img
                src={product.image}
                srcset={`${product.image} 1x, ${product.image2x} 2x`}
                width="800" height="800"
                alt={product.alt}
                loading="eager"
                decoding="async"
                class="absolute inset-0 w-full h-full object-cover"
              />
              <div class="absolute inset-3 border border-white/12 pointer-events-none"></div>
            </div>
          )}
        </div>

      </div>
    </div>
  </section>

  <!-- ====== DETAIL GALLERY ====== -->
  {product.detailImages && product.detailImages.length > 0 && (
    <section class="relative bg-bg-primary border-b border-border py-16 sm:py-20 lg:py-24">
      <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-14">
        <span class="label-dot" data-anim="fade">Detaily</span>
        <p class="text-[0.875rem] text-text-muted leading-relaxed mt-4 max-w-xs">
          Každý úhel vypráví příběh.
        </p>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8 mt-12" data-anim="stagger">
          {product.detailImages.map((img, i) => (
            <div data-anim-child class="relative overflow-hidden">
              <div class="aspect-[1/1] relative overflow-hidden">
                <img
                  src={img.src}
                  srcset={`${img.src} 1x, ${img.src2x} 2x`}
                  width="800" height="800"
                  alt={img.alt}
                  loading="lazy" decoding="async"
                  class="absolute inset-0 w-full h-full object-cover"
                />
                <div class="absolute inset-2 border border-white/10 pointer-events-none"></div>
                <div class="absolute top-4 left-4 bg-bg-primary/90 backdrop-blur-md px-3 py-1.5">
                  <span class="text-[0.6875rem] font-medium text-gold-on-light font-sans">{`0${i + 1}`}</span>
                </div>
              </div>
              <p class="mt-3 text-[0.8125rem] text-text-secondary font-sans">{img.alt}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ====== DALŠÍ ŠPERKY ====== -->
  <section class="relative bg-bg-primary border-b border-border py-16 sm:py-20 lg:py-24 overflow-hidden">
    <div class="radial-overlay"></div>
    <div class="relative max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-14">

      <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6 mb-14">
        <div data-anim="up">
          <span class="label-dot">Další šperky</span>
          <h2 class="mt-5">Mohlo by se vám <em>líbit</em></h2>
        </div>
        <div data-anim="up">
          <Button href="/skladem" variant="text">Všechny šperky</Button>
        </div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-10" data-anim="stagger">
        {otherProducts.map((p) => (
          <div data-anim-child>
            <ProductCard
              title={p.title}
              material={p.material}
              price={p.price}
              href={`/sperky/${p.slug}`}
              category={p.category}
              image={p.image}
              image2x={p.image2x}
              alt={p.alt}
              description={p.description}
            />
          </div>
        ))}
      </div>

    </div>
  </section>

</Layout>
