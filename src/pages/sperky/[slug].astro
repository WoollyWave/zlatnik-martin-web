---
import Layout from '../../layouts/Layout.astro';
import Button from '../../components/Button.astro';
import ImagePlaceholder from '../../components/ImagePlaceholder.astro';
import { products, type Product } from '../../data/products';

export function getStaticPaths() {
  return products.map((product) => ({
    params: { slug: product.slug },
    props: { product },
  }));
}

interface Props {
  product: Product;
}

const { product } = Astro.props;
---

<Layout
  title={`${product.title} | Martin Ševr — Zlatnická dílna`}
  description={product.description}
>
  <section class="bg-bg-primary py-16 md:py-24">
    <div class="max-w-[1400px] mx-auto px-5 md:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16">
        <!-- Photo gallery (sticky) -->
        <div class="lg:sticky lg:top-24 lg:self-start space-y-4">
          {product.image ? (
            <img
              src={product.image}
              srcset={`${product.image} 1x, ${product.image2x} 2x`}
              width="800" height="800"
              alt={product.alt}
              loading="eager"
              decoding="async"
              class="w-full h-full object-cover"
            />
          ) : (
            <ImagePlaceholder aspect="1/1" alt={product.title} class="w-full" />
          )}
          {product.detailImages && product.detailImages.length > 0 ? (
            <div class="grid grid-cols-3 gap-4">
              {product.detailImages.map((img) => (
                <img
                  src={img.src}
                  srcset={`${img.src} 1x, ${img.src2x} 2x`}
                  width="1000" height="1000"
                  alt={img.alt}
                  loading="lazy"
                  decoding="async"
                  class="w-full h-full object-cover"
                />
              ))}
            </div>
          ) : (
            <div class="grid grid-cols-3 gap-4">
              <ImagePlaceholder aspect="1/1" alt={`${product.title} — detail 1`} class="w-full" />
              <ImagePlaceholder aspect="1/1" alt={`${product.title} — detail 2`} class="w-full" />
              <ImagePlaceholder aspect="1/1" alt={`${product.title} — detail 3`} class="w-full" />
            </div>
          )}
        </div>

        <!-- Info panel -->
        <div>
          <a href="/skladem" class="inline-flex items-center text-[0.8125rem] text-text-muted hover:text-text-primary transition-colors duration-200 mb-8 uppercase tracking-[0.1em]">
            &larr;&nbsp;Zpět na Skladem
          </a>
          <h1>{product.title}</h1>
          <p class="text-[1.5rem] font-serif font-normal text-text-primary mt-4">{product.price}</p>
          <div class="mt-6 py-6 border-t border-b border-divider">
            <dl class="space-y-3">
              <div class="flex gap-4">
                <dt class="text-[0.875rem] text-text-muted w-24 flex-shrink-0">Materiál</dt>
                <dd class="text-[0.875rem] text-text-primary">{product.material}</dd>
              </div>
              <div class="flex gap-4">
                <dt class="text-[0.875rem] text-text-muted w-24 flex-shrink-0">Kategorie</dt>
                <dd class="text-[0.875rem] text-text-primary capitalize">{product.category}</dd>
              </div>
            </dl>
          </div>
          <p class="mt-6 text-text-secondary text-[1.0625rem] leading-relaxed">{product.description}</p>
          <div class="mt-8 flex flex-col sm:flex-row gap-3">
            <Button href="/kontakt" variant="primary">Chci tento šperk</Button>
            <Button href="https://wa.me/420774598181" variant="secondary">Napsat na WhatsApp</Button>
          </div>
          <p class="mt-4 text-[0.8125rem] text-text-muted">
            Osobní vyzvednutí v dílně nebo pojištěná zásilka po celé ČR.
          </p>
        </div>
      </div>
    </div>
  </section>
</Layout>
