---
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';
import Testimonial from '../components/Testimonial.astro';
import CTA from '../components/CTA.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LocalBusiness",
      "name": "Martin Ševr — Zlatnická dílna",
      "description": "Ruční výroba šperků ze zlata, stříbra a přírodních kamenů. Každý kus originál.",
      "url": "https://zlatnikmartin.cz",
      "telephone": "+420774598181",
      "email": "zlatnikmartin@email.cz",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Pod Kesnerkou 46",
        "addressLocality": "Praha 5",
        "postalCode": "150 00",
        "addressCountry": "CZ"
      },
      "priceRange": "$$$$",
      "image": "https://zlatnikmartin.cz/images/og-default.jpg"
    },
    {
      "@type": "WebSite",
      "name": "Martin Ševr — Zlatnická dílna Praha",
      "url": "https://zlatnikmartin.cz"
    }
  ]
};

const portfolioItems = [
  {
    title: 'Zlatý prsten s opálem',
    tags: ['Zlato 585', 'Opál', 'Zakázka'],
    description: 'Prsten s australským opálem zasazeným do ručně tepaného zlata. Navržen podle příběhu klientky.',
    href: '/tvorba/zlaty-prsten-s-opalem',
    label: 'Zakázka 01',
    image: '/images/homepage--portfolio-1--prsten-tahitska-perla.webp',
    image2x: '/images/homepage--portfolio-1--prsten-tahitska-perla@2x.webp',
    alt: 'Zlatý prsten s tahitskou perlou',
  },
  {
    title: 'Stříbrná sada s granáty',
    tags: ['Stříbro 925', 'České granáty'],
    description: 'Náušnice a prsten s českými granáty v minimalistickém moderním designu.',
    href: '/tvorba/stribrna-sada-s-granaty',
    label: 'Zakázka 02',
    image: '/images/homepage--portfolio-2--privesek-citrin.webp',
    image2x: '/images/homepage--portfolio-2--privesek-citrin@2x.webp',
    alt: 'Stříbrný přívěsek s citrínem',
  },
  {
    title: 'Snubní prsteny na míru',
    tags: ['Zlato 750', 'Zakázka'],
    description: 'Pár snubních prstenů s ručně rytým vzorem. Každý je originál.',
    href: '/tvorba/snubni-prsteny-na-miru',
    label: 'Zakázka 03',
    image: '/images/homepage--portfolio-3--snubni-prsteny-zlate.webp',
    image2x: '/images/homepage--portfolio-3--snubni-prsteny-zlate@2x.webp',
    alt: 'Zlaté snubní prsteny na míru',
  },
];

const processSteps = [
  {
    number: '01',
    title: 'Konzultace s vámi',
    description: 'Sejdeme se v dílně nebo po telefonu. Probereme váš nápad, materiály a rozpočet. Bez závazků.',
  },
  {
    number: '02',
    title: 'Ruční výroba v dílně',
    description: 'Každý šperk vyrábím ručně — od prvního náčrtu po finální lesk. Průběh fotím, abyste viděli, jak vzniká.',
  },
  {
    number: '03',
    title: 'Předání s certifikátem',
    description: 'Šperk předám osobně v dílně nebo zašlu pojištěnou zásilkou. Vždy s certifikátem pravosti.',
  },
];
---

<Layout
  title="Martin Ševr — Zlatnická dílna Praha | Ruční výroba šperků"
  description="Ruční výroba šperků ze zlata, stříbra a přírodních kamenů. Každý kus originál. Zakázková tvorba v Praze."
  jsonLd={jsonLd}
>

  <!-- ====== HERO ====== -->
  <section class="bg-bg-primary pt-12 md:pt-20 pb-16 md:pb-28">
    <div class="max-w-[1400px] mx-auto px-8">
      <!-- Big heading -->
      <h1 class="max-w-4xl" data-animate="up">
        Každý šperk má svůj
        <em class="italic text-gold-deep" style="font-variation-settings: 'WONK' 1, 'SOFT' 0, 'opsz' 144;">příběh</em>
      </h1>

      <!-- Sidebar label + link row -->
      <div class="grid grid-cols-1 lg:grid-cols-[280px_1fr] gap-8 lg:gap-20 mt-8">
        <div>
          <div class="flex items-center gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-gold-primary"></span>
            <span class="text-[0.6875rem] uppercase tracking-[0.15em] font-medium text-text-primary">Zlatnická dílna Praha</span>
          </div>
          <p class="text-[0.875rem] text-text-muted leading-relaxed mt-4 max-w-[240px]">
            Ručně vyráběné šperky ze zlata, stříbra a přírodních kamenů. Více než dvacet let zkušeností v každém kusu.
          </p>
        </div>
        <div class="flex items-end justify-start lg:justify-end">
          <Button href="/portfolio" variant="text">Prohlédnout portfolio</Button>
        </div>
      </div>

      <!-- Buttons -->
      <div class="mt-10 flex flex-col sm:flex-row gap-4">
        <Button href="/zakazkova-tvorba" variant="primary">Chci šperk na míru</Button>
        <Button href="/skladem" variant="secondary">Hotové šperky</Button>
      </div>

      <!-- Asymmetric photo grid -->
      <div class="grid grid-cols-1 md:grid-cols-[1.15fr_0.85fr] gap-4 mt-12" data-animate="fade" data-animate-delay="0.2">
        <img
          src="/images/homepage--hero--ametystovy-cluster-na-ruce.webp"
          srcset="/images/homepage--hero--ametystovy-cluster-na-ruce.webp 1x, /images/homepage--hero--ametystovy-cluster-na-ruce@2x.webp 2x"
          width="1200" height="900"
          alt="Ametystový prsten na ruce — ruční práce Martina Ševra"
          loading="eager"
          decoding="async"
          class="w-full h-full object-cover"
        />
        <img
          src="/images/homepage--portfolio-1--prsten-tahitska-perla.webp"
          srcset="/images/homepage--portfolio-1--prsten-tahitska-perla.webp 1x, /images/homepage--portfolio-1--prsten-tahitska-perla@2x.webp 2x"
          width="800" height="600"
          alt="Zlatý prsten s tahitskou perlou"
          loading="eager"
          decoding="async"
          class="w-full h-full object-cover"
        />
      </div>
    </div>
  </section>

  <!-- ====== SELECTED WORKS ====== -->
  <section class="bg-bg-primary border-t border-divider py-16 md:py-24">
    <div class="max-w-[1400px] mx-auto px-8">
      <div class="grid grid-cols-1 lg:grid-cols-[280px_1fr] gap-12 lg:gap-20">

        <!-- Sidebar -->
        <div>
          <div class="flex items-center gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-gold-primary"></span>
            <span class="text-[0.6875rem] uppercase tracking-[0.15em] font-medium text-text-primary">Vybrané práce</span>
          </div>
          <p class="text-[0.875rem] text-text-muted leading-relaxed mt-4 max-w-[240px]">
            Výběr z realizovaných zakázek a autorských šperků.
          </p>
        </div>

        <!-- Content -->
        <div>
          <h2 data-animate="up">
            Šperky vyrobené s
            <em class="italic text-gold-deep" style="font-variation-settings: 'WONK' 1, 'SOFT' 0, 'opsz' 144;">láskou</em>
            ke každému detailu.
          </h2>
          <div class="mt-4 flex justify-end">
            <Button href="/portfolio" variant="text">Zobrazit portfolio</Button>
          </div>
        </div>
      </div>

      <!-- Portfolio items -->
      <div class="flex flex-col gap-16 md:gap-20 mt-12">
        {portfolioItems.map((item, i) => (
          <a href={item.href} class="group grid grid-cols-1 md:grid-cols-[1.15fr_0.85fr] gap-4 items-end" data-animate="up">
            <div class={`relative overflow-hidden ${i % 2 === 1 ? 'md:order-2' : ''}`}>
              <img
                src={item.image}
                srcset={`${item.image} 1x, ${item.image2x} 2x`}
                width="800" height="600"
                alt={item.alt}
                loading="lazy"
                decoding="async"
                class="w-full h-full object-cover group-hover:opacity-90 transition-opacity duration-300"
              />
              <div class="absolute bottom-4 right-4 bg-bg-primary/90 backdrop-blur-sm px-4 py-2">
                <span class="text-[0.6875rem] uppercase tracking-[0.12em] font-medium text-gold-on-light">{item.label}</span>
              </div>
            </div>
            <div class={`py-4 ${i % 2 === 1 ? 'md:order-1' : ''}`}>
              <div class="flex flex-wrap gap-2 mb-3">
                {item.tags.map((tag: string) => (
                  <span class="text-[0.75rem] uppercase tracking-wider text-text-muted">{tag}</span>
                ))}
              </div>
              <h3>{item.title}</h3>
              <p class="mt-2 text-text-secondary text-[0.9375rem]">{item.description}</p>
              <span class="inline-block mt-3 text-[0.8125rem] font-medium text-text-primary uppercase tracking-[0.1em] group-hover:text-gold-deep transition-colors duration-200">
                Zobrazit detail &nearr;
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ====== PHILOSOPHY ====== -->
  <section class="bg-bg-primary border-t border-divider py-16 md:py-24">
    <div class="max-w-[1400px] mx-auto px-8">
      <div class="grid grid-cols-1 lg:grid-cols-[280px_1fr] gap-12 lg:gap-20">

        <!-- Sidebar -->
        <div>
          <div class="flex items-center gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-gold-primary"></span>
            <span class="text-[0.6875rem] uppercase tracking-[0.15em] font-medium text-text-primary">Filozofie dílny</span>
          </div>
          <p class="text-[0.875rem] text-text-muted leading-relaxed mt-4 max-w-[240px]">
            Přístup ke šperku jako k architektuře v malém.
          </p>
        </div>

        <!-- Content -->
        <div data-animate="up">
          <p class="font-serif italic text-[1.375rem] md:text-[1.625rem] leading-relaxed text-text-primary font-light max-w-2xl">
            Věřím ve šperky, které
            <em class="text-gold-deep" style="font-variation-settings: 'WONK' 1, 'SOFT' 0, 'opsz' 144;">dýchají</em>
            — řemeslo, které odstraní zbytečné a odhalí
            <em class="text-gold-deep" style="font-variation-settings: 'WONK' 1, 'SOFT' 0, 'opsz' 144;">krásu</em>
            materiálu.
          </p>

          <div class="border-t border-divider mt-12 pt-12">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
              <div>
                <p class="text-text-secondary text-[1.0625rem] leading-relaxed">
                  Víc než dvacet let pracuji se zlatem a stříbrem. Každý šperk vyrábím ručně — od prvního náčrtu po finální lesk. Není to jen řemeslo, je to způsob, jakým vnímám svět.
                </p>
                <p class="text-text-secondary text-[1.0625rem] leading-relaxed mt-4">
                  Každý kus, který opustí dílnu, nese kousek mého příběhu a hodně toho vašeho. Proto nespěchám a nedělám kompromisy.
                </p>
              </div>
              <div>
                <img
                  src="/images/homepage--o-dilne-preview--ruce-bruseni.webp"
                  srcset="/images/homepage--o-dilne-preview--ruce-bruseni.webp 1x, /images/homepage--o-dilne-preview--ruce-bruseni@2x.webp 2x"
                  width="800" height="600"
                  alt="Detail broušení šperku v dílně"
                  loading="lazy"
                  decoding="async"
                  class="w-full h-full object-cover"
                />
              </div>
            </div>
          </div>

          <!-- Principles -->
          <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-12">
            <div>
              <div class="border-t border-divider pt-4">
                <span class="text-[0.75rem] text-text-muted">01</span>
                <p class="mt-2 text-[0.9375rem] font-medium text-text-primary">Ruční práce bez kompromisů</p>
              </div>
            </div>
            <div>
              <div class="border-t border-divider pt-4">
                <span class="text-[0.75rem] text-text-muted">02</span>
                <p class="mt-2 text-[0.9375rem] font-medium text-text-primary">Materiály s příběhem</p>
              </div>
            </div>
            <div>
              <div class="border-t border-divider pt-4">
                <span class="text-[0.75rem] text-text-muted">03</span>
                <p class="mt-2 text-[0.9375rem] font-medium text-text-primary">Zdrženlivost místo přebytku</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ====== PROCESS ====== -->
  <section class="bg-bg-primary border-t border-divider py-16 md:py-24">
    <div class="max-w-[1400px] mx-auto px-8">
      <div class="grid grid-cols-1 lg:grid-cols-[280px_1fr] gap-12 lg:gap-20">

        <!-- Sidebar -->
        <div>
          <div class="flex items-center gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-gold-primary"></span>
            <span class="text-[0.6875rem] uppercase tracking-[0.15em] font-medium text-text-primary">Jak pracuji</span>
          </div>
          <p class="text-[0.875rem] text-text-muted leading-relaxed mt-4 max-w-[240px]">
            Od prvního nápadu po hotový šperk v jednoduchých krocích.
          </p>
        </div>

        <!-- Content: 3 steps -->
        <div class="space-y-12" data-animate-stagger>
          {processSteps.map((step) => (
            <div class="border-t border-divider pt-6">
              <span class="text-[0.75rem] text-text-muted">{step.number}</span>
              <h3 class="mt-2">{step.title}</h3>
              <p class="mt-2 text-text-secondary text-[0.9375rem] leading-relaxed max-w-lg">
                {step.description}
              </p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ====== EXPRESS ====== -->
  <section class="bg-bg-primary border-t border-divider py-16 md:py-24">
    <div class="max-w-[1400px] mx-auto px-8">
      <div class="grid grid-cols-1 lg:grid-cols-[280px_1fr] gap-12 lg:gap-20">

        <!-- Sidebar -->
        <div>
          <div class="flex items-center gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-gold-primary"></span>
            <span class="text-[0.6875rem] uppercase tracking-[0.15em] font-medium text-text-primary">Expresní výroba</span>
          </div>
        </div>

        <!-- Content -->
        <div data-animate="up">
          <h2>Šperk na poslední chvíli? Zvládnu to</h2>
          <p class="mt-4 text-text-secondary text-[1.0625rem] leading-relaxed max-w-2xl">
            Termín se blíží a potřebujete šperk dřív. Zavolejte — domluvíme expresní výrobu a řekneme si, co je reálné stihnout.
          </p>
          <div class="mt-8 flex flex-col sm:flex-row items-start gap-4">
            <Button href="tel:+420774598181" variant="primary">Zavolat</Button>
            <Button href="/zakazkova-tvorba#express" variant="text">Více o expresní výrobě</Button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ====== TESTIMONIAL ====== -->
  <Testimonial
    quote="Řekla jsem mu jen nápad a barvu kamene. Zbytek nechal na mě překvapit. Když jsem prsten poprvé viděla, věděla jsem, že přesně takhle jsem si ho představovala."
    author="Helena Novotná"
    role="Sběratelka šperků, Praha"
  />

  <!-- ====== O DÍLNĚ PREVIEW ====== -->
  <section class="bg-bg-primary border-t border-divider py-16 md:py-24">
    <div class="max-w-[1400px] mx-auto px-8">
      <div class="grid grid-cols-1 lg:grid-cols-[280px_1fr] gap-12 lg:gap-20">

        <!-- Sidebar -->
        <div>
          <div class="flex items-center gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-gold-primary"></span>
            <span class="text-[0.6875rem] uppercase tracking-[0.15em] font-medium text-text-primary">O dílně</span>
          </div>
        </div>

        <!-- Content -->
        <div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
            <div data-animate="up">
              <h2>Dílna Pod Kesnerkou</h2>
              <p class="mt-4 text-text-secondary text-[1.0625rem] leading-relaxed">
                Dílna Pod Kesnerkou je místo, kde se potkává tradice s moderním přístupem. Pracuji s certifikovanými kovy a ručně vybranými kameny. Žádná sériová výroba, žádné kompromisy.
              </p>
              <div class="mt-8">
                <Button href="/o-dilne" variant="text">Poznejte dílnu</Button>
              </div>
            </div>
            <div>
              <img
                src="/images/homepage--o-dilne-preview--ruce-bruseni.webp"
                srcset="/images/homepage--o-dilne-preview--ruce-bruseni.webp 1x, /images/homepage--o-dilne-preview--ruce-bruseni@2x.webp 2x"
                width="800" height="600"
                alt="Ruční práce v zlatnické dílně"
                loading="lazy"
                decoding="async"
                class="w-full h-full object-cover"
              />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ====== CTA PRE-FOOTER ====== -->
  <CTA
    heading={"Pojďme vytvořit šperk,\nkterý krásně zestárne."}
    subheading="Zavolejte mi nebo napište na WhatsApp. Ozvu se do 24 hodin a domluvíme se na dalším kroku."
  />

</Layout>
