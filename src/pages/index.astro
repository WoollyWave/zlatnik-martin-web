---
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LocalBusiness",
      "name": "Martin Ševr — Zlatnická dílna",
      "description": "Ruční výroba šperků ze zlata, stříbra a přírodních kamenů. Každý kus originál.",
      "url": "https://zlatnikmartin.cz",
      "telephone": "+420774598181",
      "email": "zlatnikmartin@email.cz",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Pod Kesnerkou 46",
        "addressLocality": "Praha 5",
        "postalCode": "150 00",
        "addressCountry": "CZ"
      },
      "priceRange": "$$$$",
      "image": "https://zlatnikmartin.cz/images/og-default.jpg"
    },
    {
      "@type": "WebSite",
      "name": "Martin Ševr — Zlatnická dílna Praha",
      "url": "https://zlatnikmartin.cz"
    }
  ]
};

const portfolioItems = [
  {
    title: 'Zlatý prsten s opálem',
    tags: ['Zlato 585', 'Opál', 'Zakázka'],
    description: 'Prsten s australským opálem zasazeným do ručně tepaného zlata. Navržen podle příběhu klientky.',
    href: '/tvorba/zlaty-prsten-s-opalem',
    label: 'Zakázka 01',
    image: '/images/homepage--portfolio-1--prsten-tahitska-perla.webp',
    image2x: '/images/homepage--portfolio-1--prsten-tahitska-perla@2x.webp',
    alt: 'Zlatý prsten s tahitskou perlou',
  },
  {
    title: 'Stříbrná sada s granáty',
    tags: ['Stříbro 925', 'České granáty'],
    description: 'Náušnice a prsten s českými granáty v minimalistickém moderním designu.',
    href: '/tvorba/stribrna-sada-s-granaty',
    label: 'Zakázka 02',
    image: '/images/homepage--portfolio-2--privesek-citrin.webp',
    image2x: '/images/homepage--portfolio-2--privesek-citrin@2x.webp',
    alt: 'Stříbrný přívěsek s citrínem',
  },
  {
    title: 'Snubní prsteny na míru',
    tags: ['Zlato 750', 'Zakázka'],
    description: 'Pár snubních prstenů s ručně rytým vzorem. Každý je originál.',
    href: '/tvorba/snubni-prsteny-na-miru',
    label: 'Zakázka 03',
    image: '/images/homepage--portfolio-3--snubni-prsteny-zlate.webp',
    image2x: '/images/homepage--portfolio-3--snubni-prsteny-zlate@2x.webp',
    alt: 'Zlaté snubní prsteny na míru',
  },
];

const processSteps = [
  {
    number: '01',
    title: 'Konzultace',
    description: 'Sejdeme se v dílně nebo po telefonu. Probereme váš nápad, materiály a rozpočet. Bez závazků.',
    image: '/images/zakazkova--proces-01--3d-cad-navrh.webp',
    image2x: '/images/zakazkova--proces-01--3d-cad-navrh@2x.webp',
    alt: 'Konzultace a návrh šperku',
  },
  {
    number: '02',
    title: 'Ruční výroba',
    description: 'Každý šperk vyrábím ručně — od prvního náčrtu po finální lesk. Průběh fotím, abyste viděli, jak vzniká.',
    image: '/images/zakazkova--proces-03--snubaky-v-ruce-vyroba.webp',
    image2x: '/images/zakazkova--proces-03--snubaky-v-ruce-vyroba@2x.webp',
    alt: 'Ruční výroba šperku v dílně',
  },
  {
    number: '03',
    title: 'Předání s certifikátem',
    description: 'Šperk předám osobně v dílně nebo zašlu pojištěnou zásilkou. Vždy s certifikátem pravosti.',
    image: '/images/zakazkova--proces-04--privesek-J-na-krku-predani.webp',
    image2x: '/images/zakazkova--proces-04--privesek-J-na-krku-predani@2x.webp',
    alt: 'Předání hotového šperku',
  },
];
---

<Layout
  title="Martin Ševr — Zlatnická dílna Praha | Ruční výroba šperků"
  description="Ruční výroba šperků ze zlata, stříbra a přírodních kamenů. Každý kus originál. Zakázková tvorba v Praze."
  jsonLd={jsonLd}
>

  <!-- ====== HERO ====== -->
  <section class="relative bg-bg-primary border-b border-border overflow-hidden">
    <div class="radial-overlay"></div>

    <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-14 relative">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center min-h-[calc(100svh-96px)] py-16 lg:py-24">

        <!-- Text -->
        <div class="hero-label">
          <span class="label-dot" data-anim="fade">Zlatnická dílna Praha</span>

          <h1 class="mt-6 hero-headline" data-anim="stagger">
            <span class="block">Šperky tvarované</span>
            <span class="block"><em>světlem</em> a krásou</span>
            <span class="block">materiálu.</span>
          </h1>

          <p class="subtitle mt-6 hero-copy" data-anim="up">
            Ruční výroba šperků ze zlata, stříbra a přírodních kamenů. Každá proporce, textura a přechod promyšlen s tichou precizností.
          </p>

          <div class="mt-10 flex flex-col sm:flex-row gap-4 hero-btn-group" data-anim="up">
            <Button href="/zakazkova-tvorba" variant="primary">Chci šperk na míru</Button>
            <Button href="/skladem" variant="secondary">Hotové šperky</Button>
          </div>

          <!-- Meta row -->
          <div class="grid grid-cols-3 gap-6 mt-12 pt-6 border-t border-border hero-meta" data-anim="up">
            <div>
              <span class="text-[10px] uppercase tracking-[0.16em] font-medium text-text-muted font-sans">Lokace</span>
              <p class="text-[13px] text-text-primary mt-1 font-sans">Praha — Osobní setkání</p>
            </div>
            <div>
              <span class="text-[10px] uppercase tracking-[0.16em] font-medium text-text-muted font-sans">Zaměření</span>
              <p class="text-[13px] text-text-primary mt-1 font-sans">Ruční výroba / Zakázky</p>
            </div>
            <div>
              <span class="text-[10px] uppercase tracking-[0.16em] font-medium text-text-muted font-sans">Zkušenosti</span>
              <p class="text-[13px] text-text-primary mt-1 font-sans">Více než 20 let</p>
            </div>
          </div>
        </div>

        <!-- Photo — clean, no overlays -->
        <div class="relative hero-img-wrap order-first lg:order-none" data-anim="scale">
          <img
            src="/images/homepage--hero--vltavin-privesek.webp"
            srcset="/images/homepage--hero--vltavin-privesek.webp 1x, /images/homepage--hero--vltavin-privesek@2x.webp 2x"
            width="800" height="600"
            alt="Přívěsek s vltavínem a růženínem — zakázková tvorba"
            loading="eager"
            decoding="async"
            class="w-full h-auto object-cover max-h-[70vh] lg:max-h-none"
          />
        </div>

      </div>
    </div>
  </section>


  <!-- ====== SELECTED WORKS — Vertical list ====== -->
  <section class="bg-bg-primary border-b border-border py-20 md:py-32">
    <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-14">

      <!-- Header -->
      <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6 mb-14">
        <div>
          <span class="label-dot" data-anim="fade">Vybran&eacute; pr&aacute;ce</span>
          <h2 class="mt-5" data-anim="stagger">
            <span class="block">Šperky vyrobené</span>
            <span class="block">s <em>láskou</em> ke každému detailu.</span>
          </h2>
        </div>
        <div data-anim="up">
          <Button href="/portfolio" variant="text">Zobrazit portfolio</Button>
        </div>
      </div>

      <!-- Vertical list -->
      <div class="flex flex-col">
        {portfolioItems.map((item) => (
          <a href={item.href} class="group block border-t border-border py-10 md:py-14" data-anim="up">
            <div class="grid grid-cols-1 md:grid-cols-[0.45fr_1fr] gap-8 md:gap-12 lg:gap-16 items-center">

              <!-- Photo -->
              <div class="relative aspect-[4/3] overflow-hidden">
                <img
                  src={item.image}
                  srcset={`${item.image} 1x, ${item.image2x} 2x`}
                  width="800" height="600"
                  alt={item.alt}
                  loading="lazy"
                  decoding="async"
                  class="absolute inset-0 w-full h-full object-cover grayscale-[15%] sepia-[10%] group-hover:scale-[1.03] transition-transform duration-700"
                />
                <!-- Border inset -->
                <div class="absolute inset-2 border border-white/10 pointer-events-none"></div>
                <!-- Label plaque -->
                <div class="absolute bottom-4 left-4 bg-bg-primary/90 backdrop-blur-md px-4 py-2.5 shadow-soft">
                  <span class="text-[0.6875rem] uppercase tracking-[0.15em] font-medium text-gold-on-light font-sans">{item.label}</span>
                </div>
              </div>

              <!-- Info -->
              <div class="flex items-start justify-between gap-6">
                <div>
                  <span class="text-[0.6875rem] uppercase tracking-[0.15em] font-medium text-gold-on-light font-sans">{item.label}</span>
                  <h3 class="mt-2 text-[1.5rem] md:text-[1.75rem] group-hover:text-gold-deep transition-colors duration-300">{item.title}</h3>
                  <p class="text-[0.9375rem] text-text-secondary leading-relaxed mt-3 max-w-lg font-sans">{item.description}</p>
                  <div class="flex flex-wrap gap-3 mt-5">
                    {item.tags.map((tag: string) => (
                      <span class="text-[0.6875rem] uppercase tracking-wider text-text-muted font-sans border border-border px-3 py-1.5">{tag}</span>
                    ))}
                  </div>
                </div>
                <div class="flex-shrink-0 mt-2 h-10 w-10 rounded-full border border-border flex items-center justify-center group-hover:bg-text-primary group-hover:border-text-primary transition-colors duration-300">
                  <svg class="w-4 h-4 text-text-primary group-hover:text-white transition-colors duration-300" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25" /></svg>
                </div>
              </div>

            </div>
          </a>
        ))}
        <!-- Bottom border -->
        <div class="border-t border-border"></div>
      </div>

      <!-- CTA button -->
      <div class="mt-12 text-center" data-anim="up">
        <Button href="/portfolio" variant="secondary">Celé portfolio</Button>
      </div>

    </div>
  </section>


  <!-- ====== PHILOSOPHY — bg-secondary with left rail ====== -->
  <section class="relative bg-bg-primary border-b border-border py-20 md:py-32 overflow-hidden">
    <div class="radial-overlay"></div>

    <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-14 relative">
      <div class="grid lg:grid-cols-[0.34fr_1fr] gap-12 lg:gap-16">

        <!-- Left rail -->
        <div class="lg:border-r lg:border-border lg:pr-10">
          <div class="lg:sticky lg:top-32">
            <span class="label-dot" data-anim="fade">Filozofie d&iacute;lny</span>
            <p class="text-[0.875rem] text-text-secondary leading-relaxed mt-5 max-w-[260px] font-sans">
              Přístup ke šperku jako k architektuře v malém. Méně je vždy více.
            </p>
          </div>
        </div>

        <!-- Right content -->
        <div>
          <!-- Large italic heading -->
          <p class="font-serif italic text-[1.5rem] md:text-[1.875rem] lg:text-[2.25rem] leading-[1.35] text-text-primary font-normal max-w-3xl" data-anim="up">
            Věřím ve šperky, které
            <em class="text-gold-deep not-italic" style="font-weight: 400; font-style: italic;">dýchají</em>
            — řemeslo, které odstraní zbytečné a odhalí
            <em class="text-gold-deep not-italic" style="font-weight: 400; font-style: italic;">krásu</em>
            materiálu.
          </p>

          <!-- Split: copy + image -->
          <div class="grid md:grid-cols-2 gap-10 mt-14">
            <div data-anim="up">
              <p class="text-text-secondary text-[1.0625rem] leading-relaxed font-sans">
                Víc než dvacet let pracuji se zlatem a stříbrem. Každý šperk vyrábím ručně — od prvního náčrtu po finální lesk. Není to jen řemeslo, je to způsob, jakým vnímám svět.
              </p>
              <p class="text-text-secondary text-[1.0625rem] leading-relaxed mt-4 font-sans">
                Každý kus, který opustí dílnu, nese kousek mého příběhu a hodně toho vašeho. Proto nespěchám a nedělám kompromisy.
              </p>
            </div>
            <div class="relative overflow-hidden" data-anim="up">
              <img
                src="/images/homepage--o-dilne-preview--ruce-bruseni.webp"
                srcset="/images/homepage--o-dilne-preview--ruce-bruseni.webp 1x, /images/homepage--o-dilne-preview--ruce-bruseni@2x.webp 2x"
                width="800" height="600"
                alt="Detail broušení šperku v dílně"
                loading="lazy"
                decoding="async"
                class="w-full h-full object-cover grayscale-[15%] sepia-[10%]"
              />
              <!-- Border inset -->
              <div class="absolute inset-2 border border-white/10 pointer-events-none"></div>
              <!-- Plaque -->
              <div class="absolute bottom-4 left-4 bg-bg-primary/90 backdrop-blur-md px-4 py-2.5 shadow-soft">
                <span class="text-[0.6875rem] uppercase tracking-[0.15em] font-medium text-gold-on-light font-sans">Dílna Pod Kesnerkou</span>
              </div>
            </div>
          </div>

          <!-- 3 Principles -->
          <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-14" data-anim="stagger">
            <div class="border-t border-border pt-5">
              <span class="text-[0.75rem] text-text-muted font-sans">01</span>
              <p class="mt-2 text-[0.9375rem] font-medium text-text-primary font-sans">Ruční práce bez kompromisů</p>
            </div>
            <div class="border-t border-border pt-5">
              <span class="text-[0.75rem] text-text-muted font-sans">02</span>
              <p class="mt-2 text-[0.9375rem] font-medium text-text-primary font-sans">Materiály s příběhem</p>
            </div>
            <div class="border-t border-border pt-5">
              <span class="text-[0.75rem] text-text-muted font-sans">03</span>
              <p class="mt-2 text-[0.9375rem] font-medium text-text-primary font-sans">Zdrženlivost místo přebytku</p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>


  <!-- ====== METHODOLOGY — 3 cards ====== -->
  <section class="bg-bg-primary border-b border-border py-20 md:py-32">
    <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-14">

      <!-- Header -->
      <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6 mb-14">
        <div>
          <span class="label-dot" data-anim="fade">Jak pracuji</span>
          <h2 class="mt-5" data-anim="stagger">
            <span class="block">Od nápadu ke šperku</span>
            <span class="block">v <em>třech</em> krocích.</span>
          </h2>
        </div>
      </div>

      <!-- 3 Cards -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-10" data-anim="stagger">
        {processSteps.map((step) => (
          <div class="group">
            <!-- Card photo with icon overlay -->
            <div class="relative aspect-[4/3] overflow-hidden">
              <img
                src={step.image}
                srcset={`${step.image} 1x, ${step.image2x} 2x`}
                width="800" height="600"
                alt={step.alt}
                loading="lazy"
                decoding="async"
                class="absolute inset-0 w-full h-full object-cover grayscale-[15%] sepia-[10%]"
              />
              <!-- Gradient -->
              <div class="absolute inset-0 bg-gradient-to-t from-[rgba(30,27,24,0.25)] via-transparent to-transparent pointer-events-none"></div>
              <!-- Number circle overlay -->
              <div class="absolute top-4 left-4 h-11 w-11 rounded-full border border-white/60 bg-[rgba(250,251,248,0.85)] backdrop-blur-sm flex items-center justify-center text-gold-deep text-[11px] font-medium uppercase tracking-wider font-sans shadow-[0_10px_24px_rgba(30,27,24,0.10)]">
                {step.number}
              </div>
            </div>
            <!-- Info below -->
            <div class="pt-5 pb-5 border-b border-border">
              <h3 class="text-[1.15rem]">{step.title}</h3>
              <p class="text-[0.875rem] text-text-secondary leading-relaxed mt-2 font-sans">
                {step.description}
              </p>
            </div>
          </div>
        ))}
      </div>

    </div>
  </section>


  <!-- ====== TESTIMONIAL — Quote + image ====== -->
  <section class="bg-bg-primary border-b border-border py-20 md:py-32">
    <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-14">

      <div class="grid lg:grid-cols-[1fr_0.6fr] gap-12 lg:gap-16 items-center">

        <!-- Quote side -->
        <div data-anim="up">
          <span class="label-dot mb-8 block">Reference</span>
          <blockquote>
            <p class="font-serif italic text-[1.5rem] md:text-[1.875rem] leading-relaxed text-text-primary font-normal">
              &bdquo;Řekla jsem mu jen nápad a barvu kamene. Zbytek nechal na mě překvapit. Když jsem prsten poprvé viděla, věděla jsem, že přesně takhle jsem si ho představovala.&ldquo;
            </p>
          </blockquote>
          <div class="mt-8 pt-6 border-t border-border">
            <p class="font-sans font-medium text-text-primary">Helena Novotná</p>
            <p class="text-[0.875rem] text-text-muted mt-1 font-sans">Sběratelka šperků, Praha</p>
          </div>
        </div>

        <!-- Image side -->
        <div class="relative overflow-hidden aspect-[3/4]" data-anim="up">
          <img
            src="/images/homepage--hero--ametystovy-cluster-na-ruce.webp"
            srcset="/images/homepage--hero--ametystovy-cluster-na-ruce.webp 1x, /images/homepage--hero--ametystovy-cluster-na-ruce@2x.webp 2x"
            width="800" height="1067"
            alt="Prsten s diamantem na ruce — zakázková tvorba"
            loading="lazy"
            decoding="async"
            class="absolute inset-0 w-full h-full object-cover"
          />
        </div>

      </div>

    </div>
  </section>

</Layout>
