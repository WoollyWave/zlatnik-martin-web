---
import Layout from '../layouts/Layout.astro';
import ContactForm from '../components/ContactForm.astro';
import ImagePlaceholder from '../components/ImagePlaceholder.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "name": "Kontakt — Martin Ševr",
  "url": "https://zlatnikmartin.cz/kontakt",
  "mainEntity": {
    "@type": "LocalBusiness",
    "name": "Martin Ševr — Zlatnická dílna",
    "telephone": "+420774598181",
    "email": "zlatnikmartin@email.cz",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Pod Kesnerkou 46",
      "addressLocality": "Praha 5",
      "postalCode": "150 00",
      "addressCountry": "CZ"
    }
  }
};

const contactMethods = [
  {
    label: 'Telefon',
    value: '+420 774 598 181',
    href: 'tel:+420774598181',
    description: 'Po–Pá 9:00–17:00',
  },
  {
    label: 'WhatsApp',
    value: 'Napsat zprávu',
    href: 'https://wa.me/420774598181',
    description: 'Odpovím do 24 hodin',
  },
  {
    label: 'E-mail',
    value: 'zlatnikmartin@email.cz',
    href: 'mailto:zlatnikmartin@email.cz',
    description: 'Pro obsáhlejší dotazy',
  },
];
---

<Layout
  title="Kontakt | Martin Ševr — Zlatnická dílna Praha"
  description="Kontaktujte mě přímo. Telefon, WhatsApp, e-mail. Odpovím do 24 hodin. Pod Kesnerkou 46, Praha 5."
  jsonLd={jsonLd}
>

  <!-- ====== HEADER ====== -->
  <section class="bg-bg-primary pt-16 pb-8 md:pt-24 md:pb-12">
    <div class="max-w-[1280px] mx-auto px-6 text-center">
      <h1>Pojďme si promluvit</h1>
      <p class="mt-4 text-text-secondary text-[1.125rem] max-w-xl mx-auto">
        Nechte mi zprávu nebo zavolejte. Ozvu se do 24 hodin.
      </p>
    </div>
  </section>

  <!-- ====== CONTACT METHODS ====== -->
  <section class="bg-bg-primary pb-16 md:pb-20">
    <div class="max-w-[1280px] mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12">
        {contactMethods.map((method) => (
          <a
            href={method.href}
            target={method.label === 'WhatsApp' ? '_blank' : undefined}
            rel={method.label === 'WhatsApp' ? 'noopener noreferrer' : undefined}
            class="block py-6 border-t border-divider hover:border-gold-primary transition-colors duration-200"
          >
            <h3 class="font-sans text-[0.75rem] font-medium uppercase tracking-wider text-text-muted mb-2">{method.label}</h3>
            <p class="text-[1.0625rem] text-text-primary font-medium">{method.value}</p>
            <p class="text-[0.8125rem] text-text-muted mt-1">{method.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ====== FORM + PHOTO ====== -->
  <section class="bg-bg-secondary py-20 md:py-32">
    <div class="max-w-[1280px] mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16">
        <div>
          <h2 class="mb-8">Napište mi</h2>
          <ContactForm />
        </div>
        <div class="hidden lg:block">
          <ImagePlaceholder aspect="3/4" alt="Zlatnická dílna — pracovní prostor" class="w-full sticky top-24" />
        </div>
      </div>
    </div>
  </section>

  <!-- ====== MAP ====== -->
  <section class="bg-bg-primary py-16 md:py-24">
    <div class="max-w-[1280px] mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <div>
          <h2 class="text-h3 mb-4">Kde mě najdete</h2>
          <address class="not-italic text-text-secondary leading-relaxed">
            <p class="font-medium text-text-primary">Martin Ševr — Zlatnická dílna</p>
            <p class="mt-2">Pod Kesnerkou 46</p>
            <p>Praha 5, 150 00</p>
            <p class="mt-4 text-[0.875rem]">
              <span class="font-medium text-text-primary">Po–Pá</span> 9:00–17:00
            </p>
            <p class="text-[0.875rem]">
              <span class="font-medium text-text-primary">Víkendy</span> po domluvě
            </p>
            <p class="mt-4 text-[0.8125rem] text-text-muted">IČO: 87639114</p>
          </address>
        </div>
        <div class="lg:col-span-2">
          <div class="img-placeholder rounded-[2px] w-full" style="aspect-ratio: 16/9;" role="img" aria-label="Mapa — Pod Kesnerkou 46, Praha 5">
            <svg class="w-12 h-12 opacity-40" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
            </svg>
          </div>
        </div>
      </div>
    </div>
  </section>

</Layout>
