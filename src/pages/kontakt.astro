---
import Layout from '../layouts/Layout.astro';
import ContactForm from '../components/ContactForm.astro';
import ImagePlaceholder from '../components/ImagePlaceholder.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "name": "Kontakt — Martin Ševr",
  "url": "https://zlatnikmartin.cz/kontakt",
  "mainEntity": {
    "@type": "LocalBusiness",
    "name": "Martin Ševr — Zlatnická dílna",
    "telephone": "+420774598181",
    "email": "zlatnikmartin@email.cz",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Pod Kesnerkou 46",
      "addressLocality": "Praha 5",
      "postalCode": "150 00",
      "addressCountry": "CZ"
    }
  }
};

const contactMethods = [
  {
    icon: 'phone',
    label: 'Telefon',
    value: '+420 774 598 181',
    href: 'tel:+420774598181',
    description: 'Po–Pá 9:00–17:00',
  },
  {
    icon: 'whatsapp',
    label: 'WhatsApp',
    value: 'Napsat zprávu',
    href: 'https://wa.me/420774598181',
    description: 'Odpovím do 24 hodin',
  },
  {
    icon: 'email',
    label: 'E-mail',
    value: 'zlatnikmartin@email.cz',
    href: 'mailto:zlatnikmartin@email.cz',
    description: 'Pro obsáhlejší dotazy',
  },
];
---

<Layout
  title="Kontakt | Martin Ševr — Zlatnická dílna Praha"
  description="Kontaktujte mě přímo. Telefon, WhatsApp, e-mail. Odpovím do 24 hodin. Pod Kesnerkou 46, Praha 5."
  jsonLd={jsonLd}
>

  <!-- ====== HEADER ====== -->
  <section class="bg-bg-primary pt-16 pb-8 md:pt-24 md:pb-12">
    <div class="max-w-[1280px] mx-auto px-6 text-center">
      <h1 class="text-h1 italic">Pojďme si promluvit</h1>
      <p class="mt-4 text-text-secondary text-[1.125rem] max-w-xl mx-auto">
        Nechte mi zprávu nebo zavolejte. Ozvu se do 24 hodin.
      </p>
    </div>
  </section>

  <!-- ====== CONTACT METHODS ====== -->
  <section class="bg-bg-primary pb-16 md:pb-20">
    <div class="max-w-[1280px] mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
        {contactMethods.map((method, i) => (
          <a
            href={method.href}
            target={method.label === 'WhatsApp' ? '_blank' : undefined}
            rel={method.label === 'WhatsApp' ? 'noopener noreferrer' : undefined}
            class="block bg-bg-secondary rounded-[2px] p-6 text-center hover:bg-hover-bg transition-all duration-200 hover:translate-y-[-2px]"
          >
            <div class="w-12 h-12 mx-auto mb-4 rounded-full bg-bg-tertiary flex items-center justify-center">
              {i === 0 ? (
                <!-- Phone icon -->
                <svg class="w-5 h-5 text-gold-on-light" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
                </svg>
              ) : i === 1 ? (
                <!-- Chat/WhatsApp icon -->
                <svg class="w-5 h-5 text-gold-on-light" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H8.25m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H12m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 0 1-2.555-.337A5.972 5.972 0 0 1 5.41 20.97a5.969 5.969 0 0 1-.474-.065 4.48 4.48 0 0 0 .978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25Z" />
                </svg>
              ) : (
                <!-- Email icon -->
                <svg class="w-5 h-5 text-gold-on-light" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
                </svg>
              )}
            </div>
            <h3 class="font-sans font-medium text-text-primary">{method.label}</h3>
            <p class="text-[0.9375rem] text-gold-on-light font-medium mt-1">{method.value}</p>
            <p class="text-[0.8125rem] text-text-muted mt-2">{method.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ====== FORM + PHOTO ====== -->
  <section class="bg-bg-secondary py-20 md:py-28">
    <div class="max-w-[1280px] mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16">
        <div>
          <h2 class="text-h2 mb-8">Napište mi</h2>
          <ContactForm />
        </div>
        <div class="hidden lg:block">
          <ImagePlaceholder aspect="3/4" alt="Zlatnická dílna — pracovní prostor" class="w-full sticky top-24" />
        </div>
      </div>
    </div>
  </section>

  <!-- ====== MAP ====== -->
  <section class="bg-bg-primary py-20 md:py-28">
    <div class="max-w-[1280px] mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <div>
          <h2 class="text-h3 mb-4">Kde mě najdete</h2>
          <address class="not-italic text-text-secondary leading-relaxed">
            <p class="font-medium text-text-primary">Martin Ševr — Zlatnická dílna</p>
            <p class="mt-2">Pod Kesnerkou 46</p>
            <p>Praha 5, 150 00</p>
            <p class="mt-4 text-[0.875rem]">
              <span class="font-medium text-text-primary">Po–Pá</span> 9:00–17:00
            </p>
            <p class="text-[0.875rem]">
              <span class="font-medium text-text-primary">Víkendy</span> po domluvě
            </p>
            <p class="mt-4 text-[0.8125rem] text-text-muted">IČO: 87639114</p>
          </address>
        </div>
        <div class="lg:col-span-2">
          <!-- Google Maps placeholder -->
          <div class="img-placeholder rounded-[2px] w-full" style="aspect-ratio: 16/9;" role="img" aria-label="Mapa — Pod Kesnerkou 46, Praha 5">
            <svg class="w-12 h-12 opacity-40" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
            </svg>
          </div>
        </div>
      </div>
    </div>
  </section>

</Layout>
