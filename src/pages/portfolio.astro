---
import Layout from '../layouts/Layout.astro';
import CTA from '../components/CTA.astro';
import { portfolioItems } from '../data/portfolio';
---

<Layout
  title="Portfolio | Martin Ševr — Zlatnická dílna Praha"
  description="Každý kus vypráví příběh. Zlaté prsteny, stříbrné přívěsky, sady s kameny. Ruční práce Martina Ševra."
>

  <!-- ====== HERO — Parallax photo ====== -->
  <section class="relative h-[50vh] md:h-[65vh] overflow-hidden">
    <div class="absolute inset-0" data-parallax>
      <img
        src="/images/portfolio--1--prsten-opal-trojuhelnik.webp"
        srcset="/images/portfolio--1--prsten-opal-trojuhelnik.webp 1x, /images/portfolio--1--prsten-opal-trojuhelnik@2x.webp 2x"
        width="1920" height="1080"
        alt="Zlatnická dílna — portfolio šperků"
        loading="eager"
        decoding="async"
        class="w-full h-[120%] object-cover"
      />
    </div>
  </section>

  <!-- ====== HEADER — Section Label ====== -->
  <section class="bg-bg-primary pt-16 pb-8 md:pt-24 md:pb-12">
    <div class="max-w-[1400px] mx-auto px-5 md:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-[280px_1fr] gap-12 lg:gap-20">

        <!-- Sidebar label -->
        <div>
          <div class="flex items-center gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-gold-primary"></span>
            <span class="text-[0.6875rem] uppercase tracking-[0.15em] font-medium text-text-primary">Portfolio</span>
          </div>
          <p class="text-[0.875rem] text-text-muted leading-relaxed mt-4 max-w-[240px]">
            Výběr z toho, co jsem za roky vyrobil. Každý šperk má svůj příběh.
          </p>
        </div>

        <!-- Heading -->
        <div>
          <h1>Šperky z <em class="italic text-gold-deep" style="font-weight: 400;">duše</em></h1>
          <p class="mt-4 text-text-secondary text-[1.0625rem] leading-relaxed max-w-xl">
            Každý kus vypráví příběh — a rád vám ho povídám.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- ====== GALLERY — 2-col grid ====== -->
  <section class="bg-bg-primary pb-20 md:pb-28">
    <div class="max-w-[1400px] mx-auto px-5 md:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-16 md:gap-x-10 md:gap-y-20">
        {portfolioItems.map((item, i) => (
          <a href={`/tvorba/${item.slug}`} class="group block" data-animate="up">
            <!-- Photo -->
            <div class="overflow-hidden aspect-[4/5]">
              <img
                src={item.image}
                srcset={`${item.image} 1x, ${item.image2x} 2x`}
                width="800" height="1000"
                alt={item.alt}
                loading={i < 2 ? 'eager' : 'lazy'}
                decoding="async"
                class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.03]"
              />
            </div>
            <!-- Info -->
            <div class="mt-5">
              <div class="flex items-center gap-3 mb-3">
                {item.tags.map((tag: string, ti: number) => (
                  <>
                    <span class="text-[0.6875rem] font-medium uppercase tracking-[0.1em] text-text-muted">{tag}</span>
                    {ti < item.tags.length - 1 && <span class="w-px h-3 bg-divider"></span>}
                  </>
                ))}
              </div>
              <h3 class="group-hover:text-gold-deep transition-colors duration-300">{item.title}</h3>
              <p class="mt-2 text-text-secondary text-[0.9375rem] leading-relaxed">{item.description}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ====== CTA ====== -->
  <CTA
    heading={"Chcete podobný šperk <em class='italic text-gold-deep' style='font-weight: 400;'>na míru</em>"}
    subheading="Každý šperk v portfoliu začal jednoduchým nápadem. Řekněte mi ten svůj."
  />

</Layout>
