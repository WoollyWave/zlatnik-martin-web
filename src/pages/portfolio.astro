---
import Layout from '../layouts/Layout.astro';
import CTA from '../components/CTA.astro';
import { portfolioItems } from '../data/portfolio';
---

<Layout
  title="Portfolio | Martin Ševr — Zlatnická dílna Praha"
  description="Každý kus vypráví příběh. Zlaté prsteny, stříbrné přívěsky, sady s kameny. Ruční práce Martina Ševra."
>

  <!-- ====== HERO — Parallax photo ====== -->
  <section class="relative h-[50vh] md:h-[65vh] overflow-hidden">
    <div class="absolute inset-0" data-parallax>
      <img
        src="/images/portfolio--1--prsten-opal-trojuhelnik.webp"
        srcset="/images/portfolio--1--prsten-opal-trojuhelnik.webp 1x, /images/portfolio--1--prsten-opal-trojuhelnik@2x.webp 2x"
        width="1920" height="1080"
        alt="Zlatnická dílna — portfolio šperků"
        loading="eager"
        decoding="async"
        class="w-full h-[120%] object-cover"
      />
    </div>
  </section>

  <!-- ====== PORTFOLIO GRID ====== -->
  <section class="relative bg-bg-primary border-b border-border py-16 sm:py-20 lg:py-24 overflow-hidden">
    <div class="radial-overlay"></div>
    <div class="relative max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-14">

      <!-- Header -->
      <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6 mb-14" data-anim="up">
        <div>
          <span class="label-dot">Portfolio</span>
          <h1 class="mt-5">Šperky z <em>duše</em></h1>
          <p class="mt-3 text-text-secondary max-w-lg">Každý šperk v tomto portfoliu vznikl jako originál.</p>
        </div>
      </div>

      <!-- Cards: asymmetric like homepage Selected Works -->
      <div class="flex flex-col gap-16 md:gap-20">
        {portfolioItems.map((item, i) => (
          <a href={`/tvorba/${item.slug}`} class="group grid grid-cols-1 md:grid-cols-[1.08fr_0.92fr] gap-6 lg:gap-10 items-center" data-anim="up">
            <div class={`relative overflow-hidden aspect-[4/5] ${i % 2 === 1 ? 'md:order-2' : ''}`}>
              <img
                src={item.image}
                srcset={`${item.image} 1x, ${item.image2x} 2x`}
                width="800" height="1000"
                alt={item.alt}
                loading={i < 2 ? 'eager' : 'lazy'}
                decoding="async"
                class="absolute inset-0 w-full h-full object-cover grayscale-[15%] sepia-[10%] transition-transform duration-700 group-hover:scale-[1.03]"
              />
              <div class="absolute inset-2 border border-white/10 pointer-events-none"></div>
              <div class="absolute bottom-4 right-4 bg-bg-primary/90 backdrop-blur-md px-4 py-2">
                <span class="text-[0.6875rem] uppercase tracking-[0.12em] font-medium text-gold-on-light font-sans">{`Zakázka 0${i + 1}`}</span>
              </div>
            </div>
            <div class={i % 2 === 1 ? 'md:order-1' : ''}>
              <div class="flex gap-3 mb-3">
                {item.tags.map((tag: string) => (
                  <span class="text-[0.6875rem] uppercase tracking-wider text-text-muted font-sans border border-border px-3 py-1.5">{tag}</span>
                ))}
              </div>
              <h3 class="group-hover:text-gold-deep transition-colors duration-300">{item.title}</h3>
              <p class="mt-2 text-text-secondary text-[0.9375rem] leading-relaxed">{item.description}</p>
            </div>
          </a>
        ))}
      </div>

    </div>
  </section>

  <!-- ====== CTA ====== -->
  <section class="bg-bg-secondary relative overflow-hidden py-16 sm:py-20 lg:py-24">
    <div class="radial-overlay"></div>
    <div class="relative max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-14">
      <CTA heading="Chcete podobný šperk<br />na <em>míru</em>?" subheading="Zavolejte a probereme vaši představu." />
    </div>
  </section>

</Layout>
